{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Fatal",
      "Override": {
        "Microsoft": "Fatal",
        "Microsoft.AspNetCore": "Fatal",
        "Microsoft.EntityFrameworkCore": "Fatal"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "ShopApi"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ShopDb": "Host=localhost;Port=5432;Database=shopapi;Username=docker;Password=docker"
  },
  "Jwt": {
    "Issuer": "shop-api",
    "Audience": "shop-api-clients",
    "Secret": "set-a-very-long-secret-with-at-least-32-characters-please-1234567890",
    "ExpiracaoEmHoras": 8
  }
}
