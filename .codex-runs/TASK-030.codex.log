ver:text-rose-200`}\r\n            type=\"button\"\r\n            role=\"menuitem\"\r\n            onClick={onSignOut}\r\n          >\r\n            Sair\r\n          </button>\r\n        </>\r\n      ) : (\r\n        <Link className={menuItemClasses} to=\"/entrar\" role=\"menuitem\">\r\n          Entrar\r\n        </Link>\r\n      )}\r\n    </DropdownMenu>\r\n  )\r\n}\r\n\r\nfunction CategoryNavigation({ categories }: Pick<HeaderProps, 'categories'>) {\r\n  return (\r\n    <nav aria-label=\"Categorias de produtos\" className=\"border-t border-ink-800\">\r\n      <div className=\"container-page overflow-x-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden\">\r\n        <ul className=\"flex min-w-max items-center gap-1 py-2\">\r\n          <li>\r\n            <Link\r\n              className=\"flex min-h-10 items-center whitespace-nowrap rounded-xl px-3 text-sm font-medium text-brand-400 hover:bg-ink-800 hover:text-brand-300\"\r\n              to=\"/\"\r\n            >\r\n              Todas as categorias\r\n            </Link>\r\n          </li>\r\n          {categories?.map((category) => (\r\n            <li key={category.id}>\r\n              <Link\r\n                className=\"flex min-h-10 items-center whitespace-nowrap rounded-xl px-3 text-sm text-zinc-300 hover:bg-ink-800 hover:text-zinc-50\"\r\n                to={`/?categoria=${encodeURIComponent(category.id)}`}\r\n              >\r\n                {category.title}\r\n              </Link>\r\n            </li>\r\n          ))}\r\n        </ul>\r\n      </div>\r\n    </nav>\r\n  )\r\n}\r\n\r\nexport function Header({ categories = [], customer = null, onSignOut }: HeaderProps) {\r\n  return (\r\n    <header className=\"sticky top-0 z-30 border-b border-ink-800 bg-ink-950/90 backdrop-blur-xl\">\r\n      <div className=\"container-page py-2.5\">\r\n        <div className=\"flex items-center gap-2 sm:gap-3\">\r\n          <Link className=\"flex min-h-11 shrink-0 items-center gap-2 rounded-xl\" to=\"/\" aria-label=\"Shop — ir ao catálogo\">\r\n            <span className=\"grid size-9 place-items-center rounded-xl bg-brand-500 font-black text-ink-950\">\r\n              S\r\n            </span>\r\n            <span className=\"hidden text-lg font-bold tracking-tight text-zinc-50 sm:inline\">\r\n              shop<span className=\"text-brand-400\">.</span>\r\n            </span>\r\n          </Link>\r\n\r\n          <div className=\"hidden min-w-0 flex-1 md:flex\">\r\n            <SearchForm />\r\n          </div>\r\n\r\n          <nav className=\"ml-auto flex items-center gap-1\" aria-label=\"Ações da loja\">\r\n            <Link\r\n              className=\"flex min-h-10 items-center gap-2 rounded-xl px-3 text-zinc-200 hover:bg-ink-750\"\r\n              to=\"/carrinho\"\r\n              aria-label=\"Carrinho\"\r\n            >\r\n              <Icon>\r\n                <circle cx=\"9\" cy=\"20\" r=\"1\" />\r\n                <circle cx=\"19\" cy=\"20\" r=\"1\" />\r\n                <path d=\"M3 3h2l2.4 12.4A2 2 0 0 0 9.4 17h8.2a2 2 0 0 0 2-1.6L22 7H6\" />\r\n              </Icon>\r\n              <span className=\"hidden text-sm lg:inline\">Carrinho</span>\r\n            </Link>\r\n            <CustomerMenu customer={customer} onSignOut={onSignOut} />\r\n          </nav>\r\n        </div>\r\n\r\n        <div className=\"pt-2 md:hidden\">\r\n          <SearchForm />\r\n        </div>\r\n      </div>\r\n      <CategoryNavigation categories={categories} />\r\n    </header>\r\n  )\r\n}\r\n\r\nimport { Link } from 'react-router-dom'\r\n\r\nconst navigation = [\r\n  { label: 'Catálogo', to: '/' },\r\n  { label: 'Carrinho', to: '/carrinho' },\r\n  { label: 'Meus pedidos', to: '/pedidos' },\r\n  { label: 'Minha conta', to: '/minha-conta/dados' },\r\n] as const\r\n\r\nconst paymentMethods = ['Pix', 'Cartão', 'Boleto'] as const\r\n\r\nexport function Footer() {\r\n  return (\r\n    <footer className=\"border-t border-ink-800 bg-ink-900\">\r\n      <div className=\"container-page grid gap-8 py-10 sm:grid-cols-2 lg:grid-cols-3\">\r\n        <div>\r\n          <Link\r\n            className=\"inline-flex min-h-10 items-center gap-2 rounded-xl\"\r\n            to=\"/\"\r\n            aria-label=\"Shop — ir ao catálogo\"\r\n          >\r\n            <span className=\"grid size-8 place-items-center rounded-lg bg-brand-500 font-black text-ink-950\">\r\n              S\r\n            </span>\r\n            <span className=\"font-bold text-zinc-50\">\r\n              shop<span className=\"text-brand-400\">.</span>\r\n            </span>\r\n          </Link>\r\n          <p className=\"mt-3 max-w-xs text-sm text-zinc-500\">\r\n            Consulte os produtos disponíveis em nosso catálogo.\r\n          </p>\r\n        </div>\r\n\r\n        <nav aria-label=\"Navegação do rodapé\">\r\n          <h2 className=\"text-sm font-semibold text-zinc-200\">Navegação</h2>\r\n          <ul className=\"mt-3 space-y-2 text-sm text-zinc-400\">\r\n            {navigation.map((item) => (\r\n              <li key={item.to}>\r\n                <Link className=\"rounded hover:text-zinc-100\" to={item.to}>\r\n                  {item.label}\r\n                </Link>\r\n              </li>\r\n            ))}\r\n          </ul>\r\n        </nav>\r\n\r\n        <section aria-labelledby=\"footer-payment-methods\">\r\n          <h2 id=\"footer-payment-methods\" className=\"text-sm font-semibold text-zinc-200\">\r\n            Formas de pagamento\r\n          </h2>\r\n          <ul className=\"mt-3 flex flex-wrap gap-2\">\r\n            {paymentMethods.map((method) => (\r\n              <li\r\n                className=\"rounded-full border border-ink-700 bg-ink-800 px-3 py-1 text-xs text-zinc-300\"\r\n                key={method}\r\n              >\r\n                {method}\r\n              </li>\r\n            ))}\r\n          </ul>\r\n        </section>\r\n      </div>\r\n\r\n      <div className=\"border-t border-ink-800\">\r\n        <div className=\"container-pag