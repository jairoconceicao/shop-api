('useAuthStore', () => {\r\nfrontend/src\\features\\auth\\store\\authStore.test.ts:23:    useAuthStore.setState({ session: null, persistence: 'session' })\r\nfrontend/src\\features\\auth\\store\\authStore.test.ts:26:  afterEach(() => useAuthStore.getState().clearSession())\r\nfrontend/src\\features\\auth\\store\\authStore.test.ts:29:    useAuthStore.getState().setSession(session, 'session')\r\nfrontend/src\\features\\auth\\store\\authStore.test.ts:39:    useAuthStore.getState().setSession(session, 'session')\r\nfrontend/src\\features\\auth\\store\\authStore.test.ts:40:    useAuthStore.getState().setSession(session, 'local')\r\nfrontend/src\\features\\auth\\store\\authStore.test.ts:47:    useAuthStore.getState().setSession(session, 'local')\r\nfrontend/src\\features\\auth\\store\\authStore.test.ts:49:    useAuthStore.getState().clearSession()\r\nfrontend/src\\features\\auth\\store\\authStore.test.ts:51:    expect(useAuthStore.getState().session).toBeNull()\r\nfrontend/src\\features\\auth\\store\\authStore.ts:7:export type AuthSession = {\r\nfrontend/src\\features\\auth\\store\\authStore.ts:10:  expiraEm: string\r\nfrontend/src\\features\\auth\\store\\authStore.ts:19:  session: AuthSession | null\r\nfrontend/src\\features\\auth\\store\\authStore.ts:21:  setSession: (session: AuthSession, persistence: AuthPersistence) => void\r\nfrontend/src\\features\\auth\\store\\authStore.ts:67:export const useAuthStore = create<AuthState>()(\r\nimport { useQueryClient } from '@tanstack/react-query'\r\nimport { fireEvent, render, screen } from '@testing-library/react'\r\nimport { useLocation } from 'react-router-dom'\r\nimport { describe, expect, it } from 'vitest'\r\n\r\nimport { queryClient } from '../../shared/query/queryClient'\r\nimport { AppProviders } from './AppProviders'\r\nimport { useFeedback } from './feedbackContext'\r\n\r\nfunction ProviderConsumer() {\r\n  const location = useLocation()\r\n  const currentQueryClient = useQueryClient()\r\n  const { announce } = useFeedback()\r\n\r\n  return (\r\n    <>\r\n      <p>Rota: {location.pathname}</p>\r\n      <p>Query client: {currentQueryClient === queryClient ? 'ativo' : 'inativo'}</p>\r\n      <button type=\"button\" onClick={() => announce('Operação concluída')}>\r\n        Publicar feedback\r\n      </button>\r\n    </>\r\n  )\r\n}\r\n\r\ndescribe('AppProviders', () => {\r\n  it('composes router, query and feedback providers', () => {\r\n    render(\r\n      <AppProviders>\r\n        <ProviderConsumer />\r\n      </AppProviders>,\r\n    )\r\n\r\n    expect(screen.getByText(`Rota: ${window.location.pathname}`)).toBeInTheDocument()\r\n    expect(screen.getByText('Query client: ativo')).toBeInTheDocument()\r\n\r\n    fireEvent.click(screen.getByRole('button', { name: 'Publicar feedback' }))\r\n\r\n    expect(screen.getByRole('status')).toHaveTextContent('Operação concluída')\r\n  })\r\n})\r\n\r\nimport '@testing-library/jest-dom/vitest'\r\nimport { cleanup } from '@testing-library/react'\r\nimport { afterAll, afterEach, beforeAll } from 'vitest'\r\nimport { server } from './server'\r\n\r\nbeforeAll(() => server.listen({ onUnhandledRequest: 'error' }))\r\nafterEach(() => {\r\n  cleanup()\r\n  server.resetHandlers()\r\n})\r\nafterAll(() => server.close())\r\n\r\nimport tailwindcss from '@tailwindcss/vite'\r\nimport react from '@vitejs/plugin-react'\r\nimport { configDefaults, defineConfig } from 'vitest/config'\r\n\r\nexport default defineConfig({\r\n  plugins: [react(), tailwindcss()],\r\n  test: {\r\n    environment: 'jsdom',\r\n    setupFiles: './src/shared/testing/setup.ts',\r\n    exclude: [...configDefaults.exclude, '**/e2e/**'],\r\n  },\r\n})\r\n\r\n","exit_code":0,"status":"completed"}}
