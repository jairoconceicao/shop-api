{"type":"item.completed","item":{"id":"item_9","type":"command_execution","command":"\"C:\\\\Program Files\\\\PowerShell\\\\7\\\\pwsh.exe\" -Command \"Get-Content .\\\\frontend\\\\src\\\\app\\\\domains\\\\catalog\\\\products-page-pagination.context.ts\"","aggregated_output":"import { computed, type Signal } from '@angular/core';\r\n\r\nimport type { IncrementalSectionPagination } from '../home/home-featured-products.context';\r\n\r\nexport interface CatalogPaginationMetric {\r\n  readonly label: string;\r\n  readonly value: Signal<string>;\r\n  readonly ariaLabel: Signal<string>;\r\n}\r\n\r\nexport interface ProductsPagePaginationState {\r\n  readonly metrics: readonly CatalogPaginationMetric[];\r\n}\r\n\r\nexport function createProductsPagePaginationState(\r\n  pagination: Signal<IncrementalSectionPagination>,\r\n  isLoading: Signal<boolean>,\r\n): ProductsPagePaginationState {\r\n  const metricValue = (label: string, extract: (value: IncrementalSectionPagination) => number): CatalogPaginationMetric => ({\r\n    label,\r\n    value: computed(() => (isLoading() ? '...' : `${extract(pagination())}`)),\r\n    ariaLabel: computed(() => (isLoading() ? `${label} carregando` : `${label} ${extract(pagination())}`)),\r\n  });\r\n\r\n  return {\r\n    metrics: [\r\n      metricValue('Página', (value) => value.page),\r\n      metricValue('Tamanho', (value) => value.size),\r\n      metricValue('Total de itens', (value) => value.totalItems),\r\n    ] as const,\r\n  };\r\n}\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_7","type":"command_execution","command":"\"C:\\\\Program Files\\\\PowerShell\\\\7\\\\pwsh.exe\" -Command \"Get-Content .\\\\frontend\\\\src\\\\app\\\\domains\\\\catalog\\\\products-page-filters.context.ts\"","aggregated_output":"import { inject, signal, type Signal } from '@angular/core';\r\n\r\nimport { CategoryService } from '@core/category/category.service';\r\nimport type { Category } from '@shared/models';\r\n\r\nimport { createRemoteSectionState } from '../home/home-page.context';\r\n\r\nexport interface ProductsPageFiltersState {\r\n  readonly categories: Signal<readonly Category[]>;\r\n  readonly isLoadingCategories: Signal<boolean>;\r\n  readonly categoriesError: Signal<string | null>;\r\n  readonly isCategoriesEmpty: Signal<boolean>;\r\n  readonly selectedCategoryId: Signal<number | null>;\r\n  reloadCategories(): void;\r\n  selectCategory(categoryId: number | null): void;\r\n}\r\n\r\nexport function createProductsPageFiltersState(\r\n  initialCategoryId: number | null = null,\r\n): ProductsPageFiltersState {\r\n  const categoryService = inject(CategoryService);\r\n  const selectedCategoryId = signal<number | null>(initialCategoryId);\r\n\r\n  const categoriesState = createRemoteSectionState<Category>(\r\n    () => categoryService.listPublicCategories(),\r\n    'Nao foi possivel carregar as categorias. Tente novamente.',\r\n  );\r\n\r\n  return {\r\n    categories: categoriesState.items,\r\n    isLoadingCategories: categoriesState.isLoading,\r\n    categoriesError: categoriesState.error,\r\n    isCategoriesEmpty: categoriesState.isEmpty,\r\n    selectedCategoryId,\r\n    reloadCategories: categoriesState.reload,\r\n    selectCategory(categoryId: number | null): void {\r\n      selectedCategoryId.set(categoryId);\r\n    },\r\n  };\r\n}\r\n","exit_code":0,"status":"completed"}}
