ternals de outra; integrações passam por uma interface pública pequena e explícita.\r\ndocs/frontend-implementation-plan-v2.md-55-- `shared` contém somente elementos realmente reutilizados por duas ou mais features.\r\ndocs/frontend-implementation-plan-v2.md-56-- Não usar barrel files globais; preferir imports diretos e caminhos estaticamente analisáveis.\r\ndocs/frontend-implementation-plan-v2.md-57-- Componentes de página coordenam dados; componentes visuais recebem props simples e não conhecem HTTP.\r\n--\ndocs/frontend-implementation-plan-v2.md-175-- Tailwind v4 e tokens do protótipo.\r\ndocs/frontend-implementation-plan-v2.md-176-- ESLint, formatação, typecheck e scripts de CI.\r\ndocs/frontend-implementation-plan-v2.md-177-- Vitest, Testing Library, MSW e Playwright.\r\ndocs/frontend-implementation-plan-v2.md-178-- Variáveis de ambiente validadas.\r\ndocs/frontend-implementation-plan-v2.md-179-- Schemas Zod, adapters, envelopes e erro normalizado.\r\ndocs/frontend-implementation-plan-v2.md:180:- `apiClient`, QueryClient e providers.\r\ndocs/frontend-implementation-plan-v2.md-181-- Router e shells iniciais.\r\ndocs/frontend-implementation-plan-v2.md-182-\r\ndocs/frontend-implementation-plan-v2.md-183-Saída: build e testes smoke passam; uma consulta simulada valida a fronteira HTTP.\r\ndocs/frontend-implementation-plan-v2.md-184-\r\ndocs/frontend-implementation-plan-v2.md-185-### Fase 1 — Design system e autenticação\r\nimport { StrictMode } from 'react'\r\nimport { createRoot } from 'react-dom/client'\r\nimport { App } from './App'\r\nimport { enableMocking } from './shared/testing/enableMocking'\r\n\r\nawait enableMocking()\r\n\r\nconst rootElement = document.getElementById('root')\r\n\r\nif (!rootElement) {\r\n  throw new Error('Elemento raiz da aplicação não encontrado.')\r\n}\r\n\r\ncreateRoot(rootElement).render(\r\n  <StrictMode>\r\n    <App />\r\n  </StrictMode>,\r\n)\r\n\r\nimport './index.css'\r\n\r\nexport function App() {\r\n  return (\r\n    <main>\r\n      <h1>shop-api</h1>\r\n    </main>\r\n  )\r\n}\r\n\r\nimport { render, screen } from '@testing-library/react'\r\nimport { describe, expect, it } from 'vitest'\r\nimport { App } from './App'\r\n\r\ndescribe('App', () => {\r\n  it('renders the application heading in the DOM', () => {\r\n    render(<App />)\r\n\r\n    expect(\r\n      screen.getByRole('heading', { level: 1, name: 'shop-api' }),\r\n    ).toBeInTheDocument()\r\n  })\r\n})\r\n\r\nimport { QueryClient } from '@tanstack/react-query'\r\n\r\nimport { AppError } from '../errors/appError'\r\n\r\nexport const queryCacheDefaults = {\r\n  staleTime: 30_000,\r\n  gcTime: 5 * 60_000,\r\n} as const\r\n\r\nconst MAX_QUERY_RETRIES = 2\r\n\r\nexport function shouldRetryQuery(failureCount: number, error: unknown): boolean {\r\n  if (failureCount >= MAX_QUERY_RETRIES || !(error instanceof AppError)) {\r\n    return false\r\n  }\r\n\r\n  return error.kind === 'network' || (error.kind === 'http' && (error.status ?? 0) >= 500)\r\n}\r\n\r\nexport function createQueryClient(): QueryClient {\r\n  return new QueryClient({\r\n    defaultOptions: {\r\n      queries: {\r\n        ...queryCacheDefaults,\r\n        retry: shouldRetryQuery,\r\n        refetchOnWindowFocus: false,\r\n      },\r\n      mutations: {\r\n        retry: false,\r\n      },\r\n    },\r\n  })\r\n}\r\n\r\nexport const queryClient = createQueryClient()\r\n\r\n{\r\n  \"name\": \"shop-api-frontend\",\r\n  \"private\": true,\r\n  \"version\": \"0.0.0\",\r\n  \"type\": \"module\",\r\n  \"scripts\": {\r\n    \"dev\": \"vite\",\r\n    \"build\": \"vite build\",\r\n    \"typecheck\": \"tsc -b\",\r\n    \"lint\": \"eslint .\",\r\n    \"test\": \"vitest run\",\r\n    \"test:watch\": \"vitest\",\r\n    \"test:e2e\": \"playwright test\",\r\n    \"preview\": \"vite preview\"\r\n  },\r\n  \"dependencies\": {\r\n    \"@tanstack/react-query\": \"^5.101.2\",\r\n    \"react\": \"^19.0.0\",\r\n    \"react-dom\": \"^19.0.0\",\r\n    \"react-hook-form\": \"^7.81.0\",\r\n    \"react-router-dom\": \"^7.18.1\",\r\n    \"zod\": \"^4.4.3\",\r\n    \"zustand\": \"^5.0.14\"\r\n  },\r\n  \"devDependencies\": {\r\n    \"@eslint/js\": \"^10.0.1\",\r\n    \"@playwright/test\": \"^1.61.1\",\r\n    \"@tailwindcss/vite\": \"^4.3.2\",\r\n    \"@testing-library/jest-dom\": \"^6.9.1\",\r\n    \"@testing-library/react\": \"^16.3.2\",\r\n    \"@types/react\": \"^19.0.2\",\r\n    \"@types/react-dom\": \"^19.0.2\",\r\n    \"@vitejs/plugin-react\": \"^4.3.4\",\r\n    \"eslint\": \"^10.7.0\",\r\n    \"eslint-plugin-react-hooks\": \"^7.1.1\",\r\n    \"eslint-plugin-react-refresh\": \"^0.5.3\",\r\n    \"globals\": \"^17.7.0\",\r\n    \"jsdom\": \"^29.1.1\",\r\n    \"msw\": \"^2.15.0\",\r\n    \"tailwindcss\": \"^4.3.2\",\r\n    \"typescript\": \"~5.7.2\",\r\n    \"typescript-eslint\": \"^8.64.0\",\r\n    \"vite\": \"^6.0.5\",\r\n    \"vitest\": \"^4.1.10\"\r\n  },\r\n  \"msw\": {\r\n    \"workerDirectory\": [\r\n      \"public\"\r\n    ]\r\n  }\r\n}\r\n\r\nimport tailwindcss from '@tailwindcss/vite'\r\nimport react from '@vitejs/plugin-react'\r\nimport { defineConfig } from 'vitest/config'\r\n\r\nexport default defineConfig({\r\n  plugins: [react(), tailwindcss()],\r\n  test: {\r\n    environment: 'jsdom',\r\n    setupFiles: './src/shared/testing/setup.ts',\r\n  },\r\n})\r\n\r\nimport '@testing-library/jest-dom/vitest'\r\nimport { afterAll, afterEach, beforeAll } from 'vitest'\r\nimport { server } from './server'\r\n\r\nbeforeAll(() => server.listen({ onUnhandledRequest: 'error' }))\r\nafterEach(() => server.resetHandlers())\r\nafterAll(() => server.close())\r\n\r\n","exit_code":0,"status":"completed"}}
