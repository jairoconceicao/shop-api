{"type":"item.completed","item":{"id":"item_25","type":"command_execution","command":"\"C:\\\\Program Files\\\\PowerShell\\\\7\\\\pwsh.exe\" -Command \"Get-Content -Raw 'frontend/src/app/router/AppRouter.tsx'; Get-Content -Raw 'frontend/src/shared/ui/navigation/Pagination.tsx'; Get-Content -Raw 'frontend/src/shared/ui/states/Skeleton.tsx'; Get-Content -Raw 'frontend/src/shared/ui/states/EmptyState.tsx'; Get-Content -Raw 'frontend/src/shared/ui/states/ErrorState.tsx'; Get-Content -Raw 'frontend/package.json'\"","aggregated_output":"import { Route, Routes } from 'react-router-dom'\r\n\r\nimport { AccountLayout } from '../layouts/AccountLayout'\r\nimport { LoginPage } from '../../features/auth/pages/LoginPage'\r\nimport { RegistrationPage } from '../../features/customer/pages/RegistrationPage'\r\nimport { ProtectedRoute } from '../../features/auth/routing/ProtectedRoute'\r\nimport { PublicLayout } from '../layouts/PublicLayout'\r\nimport { StoreLayout } from '../layouts/StoreLayout'\r\nimport { NotFoundPage } from './NotFoundPage'\r\nimport { RoutePlaceholder } from './RoutePlaceholder'\r\n\r\nexport function AppRouter() {\r\n  return (\r\n    <Routes>\r\n      <Route element={<StoreLayout />}>\r\n        <Route index element={<RoutePlaceholder title=\"Catálogo\" />} />\r\n        <Route path=\"produtos/:produtoId\" element={<RoutePlaceholder title=\"Produto\" />} />\r\n        <Route element={<ProtectedRoute />}>\r\n          <Route path=\"carrinho\" element={<RoutePlaceholder title=\"Carrinho\" />} />\r\n          <Route path=\"checkout\" element={<RoutePlaceholder title=\"Checkout\" />} />\r\n          <Route\r\n            path=\"pedido-confirmado/:pedidoId\"\r\n            element={<RoutePlaceholder title=\"Pedido confirmado\" />}\r\n          />\r\n          <Route path=\"pedidos\" element={<RoutePlaceholder title=\"Pedidos\" />} />\r\n          <Route path=\"pedidos/:pedidoId\" element={<RoutePlaceholder title=\"Detalhes do pedido\" />} />\r\n          <Route path=\"minha-conta\" element={<AccountLayout />}>\r\n            <Route path=\"dados\" element={<RoutePlaceholder title=\"Dados pessoais\" />} />\r\n            <Route path=\"senha\" element={<RoutePlaceholder title=\"Alterar senha\" />} />\r\n          </Route>\r\n        </Route>\r\n      </Route>\r\n\r\n      <Route element={<PublicLayout />}>\r\n        <Route path=\"entrar\" element={<LoginPage />} />\r\n        <Route path=\"cadastro\" element={<RegistrationPage />} />\r\n        <Route path=\"*\" element={<NotFoundPage />} />\r\n      </Route>\r\n    </Routes>\r\n  )\r\n}\r\n\r\nimport type { KeyboardEvent } from 'react'\r\n\r\nexport interface PaginationProps {\r\n  page: number\r\n  totalPages: number\r\n  onPageChange: (page: number) => void\r\n  ariaLabel?: string\r\n}\r\n\r\nconst pageButtonClasses =\r\n  'inline-flex size-10 shrink-0 items-center justify-center rounded-xl text-sm font-semibold transition-colors duration-200'\r\n\r\nexport function Pagination({\r\n  page,\r\n  totalPages,\r\n  onPageChange,\r\n  ariaLabel = 'Paginação',\r\n}: PaginationProps) {\r\n  const lastPage = Math.max(1, Math.floor(totalPages))\r\n  const currentPage = clamp(Math.floor(page), 1, lastPage)\r\n  const items = getPaginationItems(currentPage, lastPage)\r\n\r\n  const changePage = (nextPage: number) => {\r\n    const normalizedPage = clamp(nextPage, 1, lastPage)\r\n\r\n    if (normalizedPage !== currentPage) {\r\n      onPageChange(normalizedPage)\r\n    }\r\n  }\r\n\r\n  const handleKeyDown = (event: KeyboardEvent<HTMLElement>) => {\r\n    const destinations: Partial<Record<string, number>> = {\r\n      ArrowLeft: currentPage - 1,\r\n      ArrowRight: currentPage + 1,\r\n      End: lastPage,\r\n      Home: 1,\r\n    }\r\n    const destination = destinations[event.key]\r\n\r\n    if (destination === undefined) {\r\n      return\r\n    }\r\n\r\n    event.preventDefault()\r\n    changePage(destination)\r\n  }\r\n\r\n  return (\r\n    <nav aria-label={ariaLabel} onKeyDown={handleKeyDown}>\r\n      <ul className=\"flex max-w-full items-center justify-center gap-1 overflow-x-auto py-1\">\r\n        <li>\r\n          <button\r\n            type=\"button\"\r\n            aria-label=\"Página anterior\"\r\n            disabled={currentPage === 1}\r\n            onClick={() => changePage(currentPage - 1)}\r\n            className={`${pageButtonClasses} text-zinc-300 hover:bg-ink-800 hover:text-zinc-50 disabled:pointer-events-none disabled:opacity-40`}\r\n          >\r\n            <span aria-hidden=\"true\">‹</span>\r\n          </button>\r\n        </li>\r\n\r\n        {items.map((item, index) =>\r\n          item === 'ellipsis' ? (\r\n            <li key={`ellipsis-${index}`} aria-hidden=\"true\" className=\"flex size-10 items-center justify-center text-zinc-500\">\r\n              …\r\n            </li>\r\n          ) : (\r\n            <li key={item}>\r\n              <button\r\n                type=\"button\"\r\n                aria-label={`Página ${item}`}\r\n                aria-current={item === currentPage ? 'page' : undefined}\r\n                onClick={() => changePage(item)}\r\n                className={`${pageButtonClasses} ${\r\n                  item === currentPage\r\n                    ? 'bg-brand-500 text-ink-950'\r\n                    : 'text-zinc-300 hover:bg-ink-800 hover:text-zinc-50'\r\n                }`}\r\n              >\r\n                {item}\r\n              </button>\r\n            </li>\r\n          ),\r\n        )}\r\n\r\n        <li>\r\n          <button\r\n            type=\"button\"\r\n            aria-label=\"Próxima página\"\r\n            disabled={currentPage === lastPage}\r\n            onClick={() => changePage(currentPage + 1)}\r\n            className={`${pageButtonClasses} text-zinc-300 hover:bg-ink-800 hover:text-zinc-50 disabled:pointer-events-none disabled:opacity-40`}\r\n          >\r\n            <span aria-hidden=\"true\">›</span>\r\n          </button>\r\n        </li>\r\n      </ul>\r\n    </nav>\r\n  )\r\n}\r\n\r\ntype PaginationItem = number | 'ellipsis'\r\n\r\nfunction getPaginationItems(currentPage: number, totalPages: number): PaginationItem[] {\r\n  if (totalPages <= 5) {\r\n    return Array.from({ length: totalPages }, (_, index) => index + 1)\r\n  }\r\n\r\n  if (currentPage <= 3) {\r\n    return [1, 2, 3, 4, 'ellipsis', totalPages]\r\n  }\r\n\r\n  if (currentPage >= totalPages - 2) {\r\n    return [1, 'ellipsis', totalPages - 3, totalPages - 2, totalPages - 1, totalPages]\r\n  }\r\n\r\n  return [1, 'ellipsis', currentPage - 1, currentPage, currentPage + 1, 'ellipsis', totalPages]\r\n}\r\n\r\nfunction clamp(value: number, min: number, max: number) {\r\n  return Math.min(Math.max(value, min), max)\r\n}\r\n\r\nimport type { HTMLAttributes } from 'react'\r\n\r\nexport interface SkeletonProps extends HTMLAttributes<HTMLDivElement> {\r\n  shape?: 'text' | 'rectangle' | 'circle'\r\n}\r\n\r\nconst shapeClasses = {\r\n  text: 'h-4 rounded-md',\r\n  rectangle: 'rounded-xl',\r\n  circle: 'aspect-square rounded-full',\r\n}\r\n\r\nexport function Skeleton({ shape = 'rectangle', className, ...props }: SkeletonProps) {\r\n  return (\r\n    <div\r\n      aria-hidden=\"true\"\r\n      className={[\r\n        'animate-pulse bg-ink-700 motion-reduce:animate-none',\r\n        shapeClasses[shape],\r\n        className,\r\n      ].filter(Boolean).join(' ')}\r\n      {...props}\r\n    />\r\n  )\r\n}\r\n\r\nimport type { HTMLAttributes, ReactNode } from 'react'\r\n\r\nexport interface EmptyStateProps extends HTMLAttributes<HTMLDivElement> {\r\n  title: string\r\n  description?: string\r\n  icon?: ReactNode\r\n  action?: ReactNode\r\n}\r\n\r\nexport function EmptyState({ title, description, icon, action, className, ...props }: EmptyStateProps) {\r\n  return (\r\n    <div className={['surface flex flex-col items-center px-6 py-10 text-center', className].filter(Boolean).join(' ')} {...props}>\r\n      {icon ? <div className=\"mb-4 text-zinc-500\" aria-hidden=\"true\">{icon}</div> : null}\r\n      <h2 className=\"text-lg font-semibold text-zinc-100\">{title}</h2>\r\n      {description ? <p className=\"mt-2 max-w-md text-sm text-zinc-400\">{description}</p> : null}\r\n      {action ? <div className=\"mt-6\">{action}</div> : null}\r\n    </div>\r\n  )\r\n}\r\n\r\nimport type { HTMLAttributes, ReactNode } from 'react'\r\n\r\nexport interface ErrorStateProps extends HTMLAttributes<HTMLDivElement> {\r\n  title?: string\r\n  description?: string\r\n  action?: ReactNode\r\n}\r\n\r\nexport function ErrorState({\r\n  title = 'Não foi possível carregar o conteúdo',\r\n  description = 'Tente novamente em alguns instantes.',\r\n  action,\r\n  className,\r\n  ...props\r\n}: ErrorStateProps) {\r\n  return (\r\n    <div role=\"alert\" className={['surface flex flex-col items-center px-6 py-10 text-center', className].filter(Boolean).join(' ')} {...props}>\r\n      <div className=\"mb-4 flex size-10 items-center justify-center rounded-full bg-rose-500/10 text-xl text-rose-300\" aria-hidden=\"true\">!</div>\r\n      <h2 className=\"text-lg font-semibold text-zinc-100\">{title}</h2>\r\n      <p className=\"mt-2 max-w-md text-sm text-zinc-400\">{description}</p>\r\n      {action ? <div className=\"mt-6\">{action}</div> : null}\r\n    </div>\r\n  )\r\n}\r\n\r\n{\r\n  \"name\": \"shop-api-frontend\",\r\n  \"private\": true,\r\n  \"version\": \"0.0.0\",\r\n  \"type\": \"module\",\r\n  \"scripts\": {\r\n    \"dev\": \"vite\",\r\n    \"build\": \"vite build\",\r\n    \"typecheck\": \"tsc -b\",\r\n    \"lint\": \"eslint .\",\r\n    \"test\": \"vitest run\",\r\n    \"test:watch\": \"vitest\",\r\n    \"test:e2e\": \"playwright test\",\r\n    \"preview\": \"vite preview\"\r\n  },\r\n  \"dependencies\": {\r\n    \"@tanstack/react-query\": \"^5.101.2\",\r\n    \"react\": \"^19.0.0\",\r\n    \"react-dom\": \"^19.0.0\",\r\n    \"react-hook-form\": \"^7.81.0\",\r\n    \"react-router-dom\": \"^7.18.1\",\r\n    \"zod\": \"^4.4.3\",\r\n    \"zustand\": \"^5.0.14\"\r\n  },\r\n  \"devDependencies\": {\r\n    \"@eslint/js\": \"^10.0.1\",\r\n    \"@playwright/test\": \"^1.61.1\",\r\n    \"@tailwindcss/vite\": \"^4.3.2\",\r\n    \"@testing-library/jest-dom\": \"^6.9.1\",\r\n    \"@testing-library/react\": \"^16.3.2\",\r\n    \"@types/react\": \"^19.0.2\",\r\n    \"@types/react-dom\": \"^19.0.2\",\r\n    \"@vitejs/plugin-react\": \"^4.3.4\",\r\n    \"eslint\": \"^10.7.0\",\r\n    \"eslint-plugin-react-hooks\": \"^7.1.1\",\r\n    \"eslint-plugin-react-refresh\": \"^0.5.3\",\r\n    \"globals\": \"^17.7.0\",\r\n    \"jsdom\": \"^29.1.1\",\r\n    \"msw\": \"^2.15.0\",\r\n    \"tailwindcss\": \"^4.3.2\",\r\n    \"typescript\": \"~5.7.2\",\r\n    \"typescript-eslint\": \"^8.64.0\",\r\n    \"vite\": \"^6.0.5\",\r\n    \"vitest\": \"^4.1.10\"\r\n  },\r\n  \"msw\": {\r\n    \"workerDirectory\": [\r\n      \"public\"\r\n    ]\r\n  }\r\n}\r\n\r\n","exit_code":0,"status":"completed"}}
