se\">\r\n            Vitrine pública\r\n          </p>\r\n          <h3 class=\"text-shop-text text-base font-bold\">\r\n            {{ product().titulo }}\r\n          </h3>\r\n        </div>\r\n\r\n        <div class=\"flex items-end justify-between gap-3\">\r\n          <div>\r\n            <p class=\"text-shop-text-light text-xs font-bold tracking-[0.2em] uppercase\">\r\n              Preço\r\n            </p>\r\n            <p class=\"text-shop-text text-xl font-black\">{{ priceLabel() }}</p>\r\n          </div>\r\n\r\n          <a\r\n            [attr.href]=\"ctaLink()\"\r\n            class=\"bg-shop-primary text-shop-text-inverted hover:bg-shop-primary-hover inline-flex rounded-full px-4 py-2 text-sm font-bold transition\"\r\n          >\r\n            {{ ctaLabel() }}\r\n          </a>\r\n        </div>\r\n      </div>\r\n    </article>\r\n  `,\r\n  changeDetection: ChangeDetectionStrategy.OnPush,\r\n})\r\nexport class ProductCardComponent {\r\n  readonly product = input.required<ProductCatalogItem>();\r\n  readonly ctaLabel = input('Comprar');\r\n  readonly ctaLink = input('/products');\r\n\r\n  protected readonly priceLabel = computed(() => this.formatCurrency(this.product().preco));\r\n  protected readonly stockLabel = computed(() => `${this.formatStock(this.product().estoque)} em estoque`);\r\n\r\n  private formatCurrency(value: number | string): string {\r\n    const numericValue = typeof value === 'string' ? Number(value) : value;\r\n\r\n    if (!Number.isFinite(numericValue)) {\r\n      return 'R$ 0,00';\r\n    }\r\n\r\n    return new Intl.NumberFormat('pt-BR', {\r\n      style: 'currency',\r\n      currency: 'BRL',\r\n    }).format(numericValue);\r\n  }\r\n\r\n  private formatStock(value: number | string): string {\r\n    const numericValue = typeof value === 'string' ? Number(value) : value;\r\n\r\n    if (!Number.isFinite(numericValue)) {\r\n      return '0';\r\n    }\r\n\r\n    return new Intl.NumberFormat('pt-BR', {\r\n      maximumFractionDigits: 0,\r\n    }).format(numericValue);\r\n  }\r\n}\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_7","type":"command_execution","command":"\"C:\\\\Program Files\\\\PowerShell\\\\7\\\\pwsh.exe\" -Command \"Get-Content frontend\\\\src\\\\app\\\\core\\\\catalog\\\\catalog.service.ts\"","aggregated_output":"import { inject, Injectable } from '@angular/core';\r\nimport { Observable } from 'rxjs';\r\n\r\nimport { ApiClientService, type PagedResponse } from '@shared/api';\r\nimport type { ProductCatalogItem } from '@shared/models';\r\n\r\nexport interface PublicProductCatalogQuery {\r\n  page?: number;\r\n  size?: number;\r\n  searchword?: string;\r\n}\r\n\r\n@Injectable({\r\n  providedIn: 'root',\r\n})\r\nexport class CatalogService {\r\n  private readonly apiClient = inject(ApiClientService);\r\n\r\n  listPublicProducts(\r\n    query: PublicProductCatalogQuery = {},\r\n  ): Observable<PagedResponse<ProductCatalogItem>> {\r\n    return this.apiClient.get<PagedResponse<ProductCatalogItem>>('/api/v1/produto', {\r\n      params: {\r\n        page: query.page ?? 1,\r\n        size: query.size ?? 4,\r\n        searchword: query.searchword,\r\n      },\r\n    });\r\n  }\r\n\r\n  listPublicProductsByCategory(\r\n    categoryId: number,\r\n    query: Pick<PublicProductCatalogQuery, 'page' | 'size'> = {},\r\n  ): Observable<PagedResponse<ProductCatalogItem>> {\r\n    return this.apiClient.get<PagedResponse<ProductCatalogItem>>(\r\n      `/api/v1/produto/categoria/${categoryId}`,\r\n      {\r\n        params: {\r\n          page: query.page ?? 1,\r\n          size: query.size ?? 4,\r\n        },\r\n      },\r\n    );\r\n  }\r\n}\r\n","exit_code":0,"status":"completed"}}
