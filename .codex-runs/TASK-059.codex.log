el}\r\n      </label>\r\n      <div className=\"inline-flex items-center gap-1 rounded-xl border border-ink-700 bg-ink-850 p-1\">\r\n        <IconButton\r\n          aria-label=\"Diminuir quantidade\"\r\n          size=\"sm\"\r\n          disabled={disabled || quantity <= normalizedMin}\r\n          onClick={() => updateQuantity(quantity - 1)}\r\n        >\r\n          −\r\n        </IconButton>\r\n        <input\r\n          id={id}\r\n          name={name}\r\n          type=\"number\"\r\n          inputMode=\"numeric\"\r\n          min={normalizedMin}\r\n          max={normalizedMax}\r\n          step={1}\r\n          value={quantity}\r\n          disabled={disabled}\r\n          onChange={handleChange}\r\n          onKeyDown={handleKeyDown}\r\n          className=\"h-9 w-12 appearance-none bg-transparent text-center text-sm font-semibold text-zinc-100 disabled:cursor-not-allowed disabled:opacity-50\"\r\n        />\r\n        <IconButton\r\n          aria-label=\"Aumentar quantidade\"\r\n          size=\"sm\"\r\n          disabled={disabled || quantity >= normalizedMax}\r\n          onClick={() => updateQuantity(quantity + 1)}\r\n        >\r\n          +\r\n        </IconButton>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n\r\nfunction clamp(value: number, min: number, max: number) {\r\n  return Math.min(Math.max(value, min), max)\r\n}\r\n\r\nfrontend/src\\App.test.tsx-35-\r\nfrontend/src\\App.test.tsx-36-  it.each([\r\nfrontend/src\\App.test.tsx-37-    ['/', 'Catálogo'],\r\nfrontend/src\\App.test.tsx-38-    ['/produtos/42', 'Produto'],\r\nfrontend/src\\App.test.tsx-39-    ['/carrinho', 'Carrinho'],\r\nfrontend/src\\App.test.tsx-40-    ['/checkout', 'Checkout'],\r\nfrontend/src\\App.test.tsx-41-    ['/pedido-confirmado/7', 'Pedido confirmado'],\r\nfrontend/src\\App.test.tsx-42-    ['/pedidos', 'Pedidos'],\r\nfrontend/src\\App.test.tsx:43:    ['/pedidos/7', 'Detalhes do pedido'],\r\nfrontend/src\\App.test.tsx-44-  ])('renders the store route %s', (route, heading) =