ut />}>\r\n        <Route path=\"entrar\" element={<LoginPage />} />\r\n        <Route path=\"cadastro\" element={<RegistrationPage />} />\r\n        <Route path=\"*\" element={<NotFoundPage />} />\r\n      </Route>\r\n    </Routes>\r\n  )\r\n}\r\n\r\n\r\n","exit_code":1,"status":"failed"}}
