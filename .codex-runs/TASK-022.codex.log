d\\ui\\states\\success-state.component.ts\r\nfrontend\\src\\app\\shared\\ui\\states\\success-state.component.spec.ts\r\nfrontend\\src\\app\\shared\\ui\\states\\skeleton-state.component.ts\r\nfrontend\\src\\app\\shared\\ui\\states\\skeleton-state.component.spec.ts\r\nfrontend\\src\\app\\shared\\ui\\states\\loading-state.component.ts\r\nfrontend\\src\\app\\shared\\ui\\states\\loading-state.component.spec.ts\r\nfrontend\\src\\app\\shared\\ui\\states\\error-state.component.ts\r\nfrontend\\src\\app\\shared\\ui\\states\\error-state.component.spec.ts\r\nfrontend\\src\\app\\shared\\ui\\states\\empty-state.component.ts\r\nfrontend\\src\\app\\shared\\ui\\states\\empty-state.component.spec.ts\r\nfrontend\\src\\app\\shared\\ui\\base\\alert.component.spec.ts\r\nfrontend\\src\\app\\shared\\ui\\base\\alert.component.ts\r\nfrontend\\src\\app\\shared\\ui\\base\\button.component.spec.ts\r\nfrontend\\src\\app\\shared\\ui\\base\\ui-id.ts\r\nfrontend\\src\\app\\shared\\ui\\base\\input.component.ts\r\nfrontend\\src\\app\\shared\\ui\\base\\input.component.spec.ts\r\nfrontend\\src\\app\\shared\\ui\\base\\form-error.component.ts\r\nfrontend\\src\\app\\shared\\ui\\base\\form-error.component.spec.ts\r\nfrontend\\src\\app\\shared\\ui\\base\\checkbox.component.ts\r\nfrontend\\src\\app\\shared\\ui\\base\\checkbox.component.spec.ts\r\nfrontend\\src\\app\\shared\\ui\\base\\button.component.ts\r\nfrontend\\src\\app\\shared\\api\\index.ts\r\nfrontend\\src\\app\\shared\\api\\api-response.normalizers.ts\r\nfrontend\\src\\app\\shared\\api\\api-response.normalizers.spec.ts\r\nfrontend\\src\\app\\shared\\api\\api-response.model.ts\r\nfrontend\\src\\app\\shared\\api\\api-response.model.spec.ts\r\nfrontend\\src\\app\\shared\\api\\api-error.normalizers.ts\r\nfrontend\\src\\app\\shared\\api\\api-error.normalizers.spec.ts\r\nfrontend\\src\\app\\shared\\api\\api-error.model.ts\r\nfrontend\\src\\app\\shared\\api\\api-client.service.ts\r\nfrontend\\src\\app\\shared\\api\\api-client.service.spec.ts\r\n","exit_cod