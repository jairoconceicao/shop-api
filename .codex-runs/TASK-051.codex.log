ibe((catalog) => {\r\n      receivedResponses.push(catalog);\r\n    });\r\n\r\n    expect(apiClientMock.get).toHaveBeenCalledWith('/api/v1/produto', {\r\n      params: {\r\n        page: 1,\r\n        size: 4,\r\n        searchword: undefined,\r\n      },\r\n    });\r\n    expect(receivedResponses).toEqual([response]);\r\n  });\r\n});\r\n","exit_code":0,"status":"completed"}}
