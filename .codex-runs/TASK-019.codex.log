ns: ApiRequestOptions = {},\r\n  47:   ): Observable<TResponse> {\r\n  48:     return this.request<TResponse, TBody>('PUT', url, body, options);\r\n  49:   }\r\n  50: \r\n  51:   patch<TResponse, TBody = unknown>(\r\n  52:     url: string,\r\n  53:     body: TBody,\r\n  54:     options: ApiRequestOptions = {},\r\n  55:   ): Observable<TResponse> {\r\n  56:     return this.request<TResponse, TBody>('PATCH', url, body, options);\r\n  57:   }\r\n  58: \r\n  59:   delete<TResponse>(url: string, options: ApiRequestOptions = {}): Observable<TResponse> {\r\n  60:     return this.request<TResponse>('DELETE', url, undefined, options);\r\n  61:   }\r\n  62: \r\n  63:   request<TResponse, TBody = unknown>(\r\n  64:     method: string,\r\n  65:     url: string,\r\n  66:     body: TBody | undefined = undefined,\r\n  67:     options: ApiRequestOptions = {},\r\n  68:   ): Observable<TResponse> {\r\n  69:     return this.httpClient.request<TResponse>(method.toUpperCase(), normalizeApiUrl(url), {\r\n  70:       body,\r\n  71:       context: options.context,\r\n  72:       headers: normalizeHeaders(options.headers),\r\n  73:       params: normalizeParams(options.params),\r\n  74:       reportProgress: options.reportProgress,\r\n  75:       responseType: 'json',\r\n  76:       withCredentials: options.withCredentials,\r\n  77:     });\r\n  78:   }\r\n  79: }\r\n  80: \r\n  81: export function normalizeApiUrl(url: string): string {\r\n  82:   const normalizedUrl = url.trim();\r\n  83: \r\n  84:   if (!normalizedUrl) {\r\n  85:     throw new Error('API request URL cannot be empty.');\r\n  86:   }\r\n  87: \r\n  88:   if (/^https?:\\/\\//i.test(normalizedUrl)) {\r\n  89:     return normalizedUrl;\r\n  90:   }\r\n  91: \r\n  92:   return normalizedUrl.startsWith('/') ? normalizedUrl : `/${normalizedUrl}`;\r\n  93: }\r\n  94: \r\n  95: function normalizeHeaders(headers?: HttpHeaders | ApiHeaders): HttpHeaders | undefined {\r\n  96:   if (!headers) {\r\n  97:     return undefined;\r\n  98: 