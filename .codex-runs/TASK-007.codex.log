}\ndocs/ideacao\\js\\theme.js-58-\ndocs/ideacao\\js\\theme.js:59:/* ---- Bases reutilizáveis (@utility) ----\ndocs/ideacao\\js\\theme.js:60:   Em Tailwind v4, @utility registra a classe como utilitário real,\ndocs/ideacao\\js\\theme.js-61-   permitindo composição via @apply e uso direto no HTML. As variantes\ndocs/ideacao\\js\\theme.js:62:   em @layer components abaixo reaproveitam estas bases. */\ndocs/ideacao\\js\\theme.js:63:@utility surface-raised {\ndocs/ideacao\\js\\theme.js-64-  @apply bg-ink-850 border border-ink-700/80 rounded-2xl shadow-xl shadow-black/40;\ndocs/ideacao\\js\\theme.js-65-}\ndocs/ideacao\\js\\theme.js-66-\ndocs/ideacao\\js\\theme.js:67:@utility btn {\ndocs/ideacao\\js\\theme.js-68-  @apply inline-flex items-center justify-center gap-2 rounded-xl px-5 py-2.5\ndocs/ideacao\\js\\theme.js-69-    text-sm font-semibold tracking-tight transition-all duration-200\ndocs/ideacao\\js\\theme.js-70-    disabled:opacity-40 disabled:pointer-events-none whitespace-nowrap;\ndocs/ideacao\\js\\theme.js-71-}\ndocs/ideacao\\js\\theme.js-72-\ndocs/ideacao\\js\\theme.js:73:@utility chip {\ndocs/ideacao\\js\\theme.js-74-  @apply inline-flex items-center gap-1.5 rounded-full px-3.5 py-1.5\ndocs/ideacao\\js\\theme.js-75-    text-xs font-medium text-zinc-400 border border-ink-700\ndocs/ideacao\\js\\theme.js-76-    hover:border-brand-500/50 hover:text-zinc-100 transition-colors cursor-pointer;\ndocs/ideacao\\js\\theme.js-77-}\ndocs/ideacao\\js\\theme.js-78-\ndocs/ideacao\\js\\theme.js:79:@utility badge {\ndocs/ideacao\\js\\theme.js-80-  @apply inline-flex items-center gap-1.5 rounded-full px-2.5 py-1\ndocs/ideacao\\js\\theme.js-81-    text-xs font-medium;\ndocs/ideacao\\js\\theme.js-82-}\ndocs/ideacao\\js\\theme.js-83-\ndocs/ideacao\\js\\theme.js:84:@layer base {\ndocs/ideacao\\js\\theme.js-85-  html {\ndocs/ideacao\\js\\theme.js-86-    scroll-behavior: smooth;\ndocs/ideacao\\js\\theme.js-87-  }\n--\ndocs/ideacao\\js\\theme.js-93-  }\ndocs/ideacao\\js\\theme.js-94-\ndo