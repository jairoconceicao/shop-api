{"type":"item.completed","item":{"id":"item_30","type":"command_execution","command":"\"C:\\\\Program Files\\\\PowerShell\\\\7\\\\pwsh.exe\" -Command \"Get-Content frontend\\\\src\\\\app\\\\domains\\\\home\\\\home-page.component.ts\"","aggregated_output":"import { ChangeDetectionStrategy, Component } from '@angular/core';\r\nimport { RouterLink } from '@angular/router';\r\nimport { PageContainerComponent } from '@shared/ui/page-container.component';\r\n\r\n@Component({\r\n  selector: 'app-home-page',\r\n  imports: [RouterLink, PageContainerComponent],\r\n  template: `\r\n    <app-page-container [wide]=\"true\">\r\n      <section class=\"space-y-8\">\r\n        <article class=\"overflow-hidden rounded-[2rem] border border-shop-border bg-[linear-gradient(135deg,#08121f_0%,#10243d_55%,#dbeafe_100%)] px-5 py-6 text-white shadow-soft sm:px-6 lg:px-10 lg:py-10\">\r\n          <div class=\"grid gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-center\">\r\n            <div>\r\n              <span class=\"inline-flex rounded-full border border-white/15 bg-white/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.24em] text-white/80\">\r\n                Ofertas da semana\r\n              </span>\r\n              <h1 class=\"mt-4 max-w-2xl text-4xl font-black tracking-tight text-balance sm:text-5xl lg:text-6xl\">\r\n                Sua vitrine mobile first para descobrir, comparar e comprar mais rapido.\r\n              </h1>\r\n              <p class=\"mt-4 max-w-2xl text-base leading-7 text-white/78 sm:text-lg\">\r\n                Uma home pensada para o celular primeiro, com caminhos curtos para categorias, promoções e produtos\r\n                em destaque.\r\n              </p>\r\n              <div class=\"mt-7 flex flex-col gap-3 sm:flex-row\">\r\n                <a\r\n                  routerLink=\"/products\"\r\n                  class=\"inline-flex items-center justify-center rounded-full bg-shop-primary px-6 py-3 text-sm font-bold text-shop-text-inverted shadow-[0_18px_38px_rgba(37,99,235,0.28)] transition hover:bg-shop-primary-hover\"\r\n                >\r\n                  Explorar vitrine\r\n                </a>\r\n                <a\r\n                  routerLink=\"/login\"\r\n                  class=\"inline-flex items-center justify-center rounded-full border border-white/20 bg-white/10 px-6 py-3 text-sm font-bold text-white transition hover:bg-white/15\"\r\n                >\r\n                  Entrar\r\n                </a>\r\n              </div>\r\n              <dl class=\"mt-8 grid gap-3 sm:grid-cols-3\">\r\n                <div class=\"rounded-2xl bg-white/10 p-4 backdrop-blur-sm\">\r\n                  <dt class=\"text-xs font-bold uppercase tracking-[0.24em] text-white/55\">Entrega</dt>\r\n                  <dd class=\"mt-2 text-lg font-bold text-white\">Rápida e rastreada</dd>\r\n                </div>\r\n                <div class=\"rounded-2xl bg-white/10 p-4 backdrop-blur-sm\">\r\n                  <dt class=\"text-xs font-bold uppercase tracking-[0.24em] text-white/55\">Parcelamento</dt>\r\n                  <dd class=\"mt-2 text-lg font-bold text-white\">Até 12x sem surpresa</dd>\r\n                </div>\r\n                <div class=\"rounded-2xl bg-white/10 p-4 backdrop-blur-sm\">\r\n                  <dt class=\"text-xs font-bold uppercase tracking-[0.24em] text-white/55\">Atendimento</dt>\r\n                  <dd class=\"mt-2 text-lg font-bold text-white\">Suporte antes e depois</dd>\r\n                </div>\r\n              </dl>\r\n            </div>\r\n\r\n            <div class=\"grid gap-3 sm:grid-cols-2 lg:max-w-xl lg:justify-self-end\">\r\n              @for (shortcut of shortcuts; track shortcut.title) {\r\n                <a\r\n                  [routerLink]=\"shortcut.link\"\r\n                  class=\"group rounded-[1.75rem] border border-white/12 bg-white/10 p-4 transition hover:-translate-y-0.5 hover:bg-white/15\"\r\n                >\r\n                  <div class=\"flex items-start justify-between gap-3\">\r\n                    <span class=\"inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-white/12 text-lg font-black text-white\">\r\n                      {{ shortcut.badge }}\r\n                    </span>\r\n                    <span class=\"rounded-full bg-white/10 px-2.5 py-1 text-[0.7rem] font-bold uppercase tracking-[0.2em] text-white/60\">\r\n                      {{ shortcut.label }}\r\n                    </span>\r\n                  </div>\r\n                  <h2 class=\"mt-4 text-lg font-bold text-white\">{{ shortcut.title }}</h2>\r\n                  <p class=\"mt-2 text-sm leading-6 text-white/70\">{{ shortcut.description }}</p>\r\n                </a>\r\n              }\r\n            </div>\r\n          </div>\r\n        </article>\r\n\r\n        <section class=\"grid gap-4 sm:grid-cols-2 lg:grid-cols-4\">\r\n          @for (category of categories; track category.title) {\r\n            <a\r\n              [routerLink]=\"category.link\"\r\n              class=\"rounded-[1.5rem] border border-shop-border bg-white p-4 shadow-soft transition hover:-translate-y-0.5 hover:border-shop-primary/30\"\r\n            >\r\n              <span class=\"inline-flex rounded-full bg-shop-secondary-soft px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-shop-secondary\">\r\n                {{ category.tag }}\r\n              </span>\r\n              <h2 class=\"mt-4 text-lg font-bold text-shop-text\">{{ category.title }}</h2>\r\n              <p class=\"mt-2 text-sm leading-6 text-shop-text-muted\">{{ category.description }}</p>\r\n            </a>\r\n          }\r\n        </section>\r\n\r\n        <section class=\"space-y-4\">\r\n          <div class=\"flex items-end justify-between gap-4\">\r\n            <div>\r\n              <p class=\"text-sm font-bold uppercase tracking-[0.24em] text-shop-text-light\">Vitrine</p>\r\n              <h2 class=\"mt-2 text-2xl font-black tracking-tight text-shop-text sm:text-3xl\">Produtos em destaque</h2>\r\n            </div>\r\n            <a routerLink=\"/products\" class=\"hidden text-sm font-bold text-shop-primary transition hover:text-shop-primary-hover sm:inline-flex\">\r\n              Ver tudo\r\n            </a>\r\n          </div>\r\n\r\n          <div class=\"grid gap-4 md:grid-cols-2 xl:grid-cols-4\">\r\n            @for (product of featuredProducts; track product.title) {\r\n              <article class=\"overflow-hidden rounded-[1.5rem] border border-shop-border bg-white shadow-soft\">\r\n                <div class=\"relative flex h-40 items-end overflow-hidden bg-[linear-gradient(135deg,#e0f2fe_0%,#bae6fd_45%,#0f172a_100%)] p-4\">\r\n                  <span class=\"rounded-full bg-white/90 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-shop-text\">\r\n                    {{ product.badge }}\r\n                  </span>\r\n                  <div class=\"absolute right-4 top-4 rounded-full bg-shop-text/85 px-3 py-1 text-xs font-bold text-white\">\r\n                    {{ product.stock }}\r\n                  </div>\r\n                </div>\r\n                <div class=\"space-y-3 p-4\">\r\n                  <div class=\"flex items-start justify-between gap-3\">\r\n                    <div>\r\n                      <p class=\"text-xs font-bold uppercase tracking-[0.2em] text-shop-text-light\">{{ product.category }}</p>\r\n                      <h3 class=\"mt-1 text-base font-bold text-shop-text\">{{ product.title }}</h3>\r\n                    </div>\r\n                    <span class=\"rounded-full bg-shop-surface-muted px-2.5 py-1 text-xs font-bold text-shop-text\">\r\n                      {{ product.rating }}\r\n                    </span>\r\n                  </div>\r\n                  <p class=\"text-sm leading-6 text-shop-text-muted\">{{ product.description }}</p>\r\n                  <div class=\"flex items-end justify-between gap-3\">\r\n                    <div>\r\n                      <p class=\"text-xs