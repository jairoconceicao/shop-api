riceLabel(value: number | string): string {\r\n 185:     const numericValue = typeof value === 'string' ? Number(value) : value;\r\n 186: \r\n 187:     if (!Number.isFinite(numericValue)) {\r\n 188:       return 'R$ 0,00';\r\n 189:     }\r\n 190: \r\n 191:     return new Intl.NumberFormat('pt-BR', {\r\n 192:       style: 'currency',\r\n 193:       currency: 'BRL',\r\n 194:     }).format(numericValue);\r\n 195:   }\r\n 196: \r\n 197:   protected stockLabel(value: number | string): string {\r\n 198:     const numericValue = typeof value === 'string' ? Number(value) : value;\r\n 199: \r\n 200:     if (!Number.isFinite(numericValue)) {\r\n 201:       return '0 em estoque';\r\n 202:     }\r\n 203: \r\n 204:     return `${new Intl.NumberFormat('pt-BR', {\r\n 205:       maximumFractionDigits: 0,\r\n 206:     }).format(numericValue)} em estoque`;\r\n 207:   }\r\n 208: }\r\n 209: \r\n 210: function parseProductId(value: string | null): number | null {\r\n 211:   if (value === null) {\r\n 212:     return null;\r\n 213:   }\r\n 214: \r\n 215:   const parsed = Number(value);\r\n 216: \r\n 217:   return Number.isInteger(parsed) && parsed > 0 ? parsed : null;\r\n 218: }\r\n--- frontend/src/app/domains/catalog/product-details-page.component.spec.ts\r\n   1: import { ActivatedRoute, convertToParamMap, provideRouter } from '@angular/router';\r\n   2: import { render, screen } from '@testing-library/angular';\r\n   3: import '@testing-library/jest-dom/vitest';\r\n   4: import { of, throwError } from 'rxjs';\r\n   5: import { beforeEach, describe, expect, it, vi } from 'vitest';\r\n   6: \r\n   7: import { CatalogService } from '@core/catalog/catalog.service';\r\n   8: \r\n   9: import { ProductDetailsPageComponent } from './product-details-page.component';\r\n  10: \r\n  11: describe('ProductDetailsPageComponent', () => {\r\n  12:   const catalogServiceMock = {\r\n  13:     getPublicProductById: vi.fn(),\r\n  14:   };\r\n  15: \r\n  16:   beforeEach(() => {\r\n  17:     catalogServic