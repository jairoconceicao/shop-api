screen.getByText('RTX')).toBeVisible();\r\n  69:     expect(screen.getByText('12 em estoque')).toBeVisible();\r\n  70:     expect(screen.getByRole('button', { name: 'Comprar agora' })).toBeVisible();\r\n  71:     expect(screen.getByRole('button', { name: 'Adicionar ao carrinho' })).toBeVisible();\r\n  72:     expect(screen.getByRole('link', { name: 'Voltar ao catalogo' })).toHaveAttribute(\r\n  73:       'href',\r\n  74:       '/products',\r\n  75:     );\r\n  76:   });\r\n  77: \r\n  78:   it('renders an error state when the API fails', async () => {\r\n  79:     catalogServiceMock.getPublicProductById.mockReturnValue(\r\n  80:       throwError(() => new Error('failed to load product')),\r\n  81:     );\r\n  82: \r\n  83:     await render(ProductDetailsPageComponent, {\r\n  84:       providers: [\r\n  85:         provideRouter([]),\r\n  86:         {\r\n  87:           provide: ActivatedRoute,\r\n  88:           useValue: createActivatedRoute(),\r\n  89:         },\r\n  90:         {\r\n  91:           provide: CatalogService,\r\n  92:           useValue: catalogServiceMock,\r\n  93:         },\r\n  94:       ],\r\n  95:     });\r\n  96: \r\n  97:     expect(screen.getByRole('alert')).toHaveTextContent('Nao foi possivel carregar o produto');\r\n  98:     expect(screen.getByRole('link', { name: 'Voltar ao catalogo' })).toHaveAttribute(\r\n  99:       'href',\r\n 100:       '/products',\r\n 101:     );\r\n 102:   });\r\n 103: });\r\n--- docs/frontend-backlog.md\r\n   1: # Backlog de tarefas do frontend da Shop API\r\n   2: \r\n   3: **Tipo de conteudo:** Backlog\r\n   4: \r\n   5: Este backlog transforma `docs/frontend-implementation-plan.md` em uma lista\r\n   6: acionavel de tarefas para implementar o frontend em `/frontend`. As tarefas\r\n   7: seguem as guidelines de `AGENTS.md`, `docs/frontend-specs.md` e os contratos\r\n   8: descritos em `docs/api-reference.md`, considerando o backend v1 atual como\r\n   9: limite pratico de integracao.\r\n  10: \r\n  11: ## Objetivo\r\n  12: \r\n  13: Entregar uma loja virtual mobile first em Angular 22+, TypeScript, Tailwind CSS\r\n  14: v4 e Angular CDK, com fluxos completos para catalogo, autenticacao, carrinho,\r\n  15: checkout e area do cliente.\r\n  16: \r\n  17: ## Status atual\r\n  18: \r\n  19: Implementacao ja identificada em `/frontend`:\r\n  20: \r\n  21: - Fundacao do projeto Angular criada e operacional.\r\n  22: - Tailwind CSS v4, Angular CDK, ESLint, Prettier, Husky, lint-staged,\r\n  23:   Testing Library Angular e Playwright configurados.\r\n  24: - Tema global, `AppShell`, `Header`, `Footer`, `MobileBottomNavigation`,\r\n  25:   `PageContainer` e paginas placeholder criados.\r\n  26: - Rotas base para `/`, `/login`, `/products`, `/cart` e `/account` criadas.\r\n  27: - Home visual inicial, tela-base de login e um smoke test de componente/e2e\r\n  28:   implementados.\r\n  29: \r\n  30: Ainda pendente no frontend atual:\r\n  31: \r\n  32: - Integracoes reais com a API.\r\n  33: - Autenticacao, sessao, guard, interceptor e stores de dominio.\r\n  34: - Formularios com schema, mascaras e estados completos.\r\n  35: - Catalogo, detalhe de produto, carrinho, checkout, conta e pedidos com\r\n  36:   comportamento funcional.\r\n  37: \r\n  38: ## Escopo\r\n  39: \r\n  40: Este backlog cobre apenas o frontend.\r\n  41: \r\n  42: Entregas incluidas:\r\n  43: \r\n  44: - Fundacao tecnica e visual do projeto Angular em `/frontend`.\r\n  45: - UI mobile first inspirada em e-commerces como Mercado Livre, Kabum e Magazine\r\n  46:   Luiza, usando identidade propria da Shop API.\r\n  47: - Integracao com os endpoints publicos de catalogo, categoria, produto, login e\r\n  48:   cadastro.\r\n  49: - Integracao autenticada para carrinho, checkout, dados do cliente, troca de\r\n  50:   senha e pedidos.\r\n  51: - Testes unitarios, testes de componentes e testes end-to-end dos fluxos\r\n  52:   principais.\r\n  53: \r\n  54: Fora do escopo inicial:\r\n  55: \r\n  56: - Gestao dedicada de multiplos enderecos salvos.\r\n  57: - Blocos promocionais dinamicos orientados por API.\r\n  58: - Curadoria administrativa de categorias.\r\n  59: \r\n  60: ## Premissas de implementacao\r\n  61: \r\n  62: - O catalogo, as categorias e o detalhe de produto sao publicos.\r\n  63: - Carrinho, checkout, conta, logout e pedidos exigem autenticacao.\r\n  64: - O login retorna `token`, `tipo`, `expiraEm`, `usuarioId`, `clienteId` e\r\n  65:   `email`; esses campos formam a sessao do frontend.\r\n  66: - A preferencia de longo prazo e cookie `HttpOnly`, mas a v1 atual usa bearer\r\n  67:   token.\r\n  68: - Respostas simples usam envelope `data`; respostas paginadas usam envelope\r\n  69:   `pagination.data`.\r\n  70: - O frontend deve normalizar os envelopes da API em uma camada compartilhada.\r\n  71: - A listagem de pedidos exige `cpf`; o frontend deve carregar o perfil do\r\n  72:   cliente antes de buscar pedidos.\r\n  73: - Ao criar carrinho, adicionar item ao carrinho e criar pedido, o frontend deve\r\n  74:   seguir o comportamento atual descrito em `docs/frontend-implementation-plan.md`:\r\n  75:   o backend deriva dados do cliente autenticado pela sessao.\r\n  76: - `PATCH /api/v1/pedido/{pedidoId}` deve ser tratado apenas como cancelamento,\r\n  77:   enviando `status: \"Cancelado\"`.\r\n  78: \r\n  79: ## Backend\r\n  80: \r\n  81: Nenhuma tarefa de backend faz parte da entrega inicial deste backlog.\r\n  82: \r\n  83: Dependencias futuras para evolucao do frontend:\r\n  84: \r\n  85: [ ] DEP-01: Expor rotas para multiplos enderecos salvos.\r\n  86: [ ] DEP-02: Expor rotas para ofertas, campanhas e promocoes dinamicas.\r\n  87: [ ] DEP-03: Expor rotas administrativas para ordenar e curar categorias.\r\n  88: [ ] DEP-04: Evoluir autenticacao para cookie `HttpOnly`, se definido como direcao do produto.\r\n  89: \r\n  90: ## Frontend\r\n  91: \r\n  92: ### 1. Fundacao do projeto\r\n  93: \r\n  94: [x] TASK-001: Criar o projeto Angular 22+ em `/frontend`.\r\n  95: [x] TASK-002: Configurar TypeScript, estrutura de paths e organizacao por dominio.\r\n  96: [x] TASK-003: Configurar Tailwind CSS v4 com tokens globais da Shop API.\r\n  97: [x] TASK-004: Configurar Angular CDK.\r\n  98: [x] TASK-005: Configurar ESLint, Prettier, Husky e lint-staged.\r\n  99: [x] TASK-006: Configurar Jest ou Vitest para testes unitarios.\r\n 100: [x] TASK-007: Configurar Testing Library Angular para testes de componentes.\r\n 101: [x] TASK-008: Configurar Playwright para testes end-to-end.\r\n 102: [x] TASK-009: Criar scripts de `lint`, `test`, `build` e `e2e`.\r\n 103: \r\n 104: ### 2. Design system e componentes base\r\n 105: \r\n 106: Entregue ate aqui:\r\n 107: \r\n 108: - Tokens globais do tema.\r\n 109: - Layout base com `AppShell`, `PageContainer`, `Header`,\r\n 110:   `MobileBottomNavigation` e `Footer`.\r\n 111: - Estrutura responsiva inicial para mobile e desktop.\r\n 112: \r\n 113: [x] TASK-010: Definir tokens de cor, tipografia, espacamento, bordas e sombras.\r\n 114: [x] TASK-011: Criar componentes base de `Button`, `Input`, `Checkbox`, `Alert` e `FormError`.\r\n 115: [x] TASK-012: Criar estados padrao de loading, skeleton, vazio, sucesso e erro.\r\n 116: [x] TASK-013: Criar componentes de layout `AppShell`, `PageContainer`, `Header`, `MobileBottomNavigation` e `Footer`.\r\n 117: [x] TASK-014: Garantir layout mobile first e adaptacao para desktop.\r\n 118: [x] TASK-015: Garantir busca e carrinho sempre acessiveis no header.\r\n 119: [x] TASK-016: Criar testes de componentes para os elementos base.\r\n 120: \r\n 121: ### 3. Camada HTTP e contratos da API\r\n 122: \r\n 123: Observacao: `provideHttpClient(withFetch())` ja foi registrado na composicao da\r\n 124: aplicacao, mas ainda nao existe uma camada HTTP compartilhada com contratos,\r\n 125: normalizadores e tratamento padrao de erros.\r\n 126: \r\n 127: [x] TASK-017: Definir modelos TypeScript para envelopes `ApiResponse<T>` e `PagedResponse<T>`.\r\n 128: [x] TASK-018: Definir modelos TypeScript para auth, cliente, categoria, produto, carrinho e pedido.\r\n 129: [x] TASK-019: Implementar cliente HTTP centralizado.\r\n 130: [x] TASK-020: Implementar normalizadores para `data` e `pagination.data`.\r\n 131: [x] TASK-021: Implementar tratamento padrao de erros da API.\r\n 132: [x] TASK-022: Implementar configuracao de URL base por ambiente.\r\n 133: [x] TASK-023: Criar testes unitarios para normalizacao de respostas e erros.\r\n 134: \r\n 135: ### 4. Autenticacao e sessao\r\n 136: \r\n 137: Observacao: existe apenas a tela visual base de `/login`; a autenticacao ainda\r\n 138: nao foi conectada ao backend e nao ha sessao, guard ou interceptor.\r\n 139: \r\n 140: [x] TASK-024: Implementar `TokenStorageService`.\r\n 141: [x] TASK-025: Implementar `AuthService` com login e logout.\r\n 142: [x] TASK-026: Implementar `HttpInterceptor` para `Authorization: Bearer <token>`.\r\n 143: [x] TASK-027: Implementar `AuthGuard` para rotas privadas.\r\n 144: [x] TASK-028: Persistir dados de sessao com `token`, `tipo`, `expiraEm`, `usuarioId`, `clienteId` e `email`.\r\n 145: [x] TASK-029: Tratar expiracao de token e redirecionamento para login.\r\n 146: [x] TASK-030: Preparar a abstracao para migracao futura para cookie `HttpOnly`.\r\n 147: [x] TASK-031: Implementar tela de login com validacao por schema.\r\n 148: [x] TASK-032: Implementar estados de erro, carregamento e sucesso no login.\r\n 149: [x] TASK-033: Criar testes unitarios e de componente para login e sessao.\r\n 150: \r\n 151: ### 5. Cadastro de cliente\r\n 152: \r\n 153: [x] TASK-034: Implementar tela publica de criacao de conta.\r\n 154: [x] TASK-035: Implementar formulario com dados pessoais, endereco e celular.\r\n 155: [x] TASK-036: Aplicar mascaras para CPF, CEP, DDD e telefone com `ngx-mask`.\r\n 156: [x] TASK-037: Aplicar validacoes por schema.\r\n 157: [x] TASK-038: Integrar `POST /api/v1/cliente`.\r\n 158: [x] TASK-039: Tratar erros de validacao e conflitos retornados pela API.\r\n 159: [x] TASK-040: Redirecionar para login ou iniciar fluxo definido apos cadastro.\r\n 160: [x] TASK-041: Criar testes de componente e integracao do formulario.\r\n 161: \r\n 162: ### 6. Home publica\r\n 163: \r\n 164: Observacao: a home visual inicial ja existe, mas ainda usa conteudo estatico e\r\n 165: nao consome categorias nem produtos da API.\r\n 166: \r\n 167: [x] TASK-042: Implementar home mobile first com banner, atalhos, categorias e vitrine.\r\n 168: [x] TASK-043: Carregar produtos publicos via `GET /api/v1/produto`.\r\n 169: [x] TASK-044: Carregar categorias via `GET /api/v1/categoria`.\r\n 170: [x] TASK-045: Implementar cards de produto com imagem, titulo, preco, estoque e CTA.\r\n 171: [x] TASK-046: Implementar estados de loading, vazio e erro.\r\n 172: [x] TASK-047: Implementar paginacao ou carregamento incremental conforme UX definida.\r\n 173: [x] TASK-048: Criar testes de componente para home, vitrine e card de produto.\r\n 174: \r\n 175: ### 7. Catalogo, busca e categorias\r\n 176: \r\n 177: Observacao: a rota `/products` ja existe como placeholder dentro do shell, mas\r\n 178: o catalogo funcional ainda nao foi implementado.\r\n 179: \r\n 180: [x] TASK-049: Implementar rota `/products`.\r\n 181: [x] TASK-050: Implementar campo de busca usando query `searchword`.\r\n 182: [x] TASK-051: Implementar filtro por categoria usando `GET /api/v1/categoria`.\r\n 183: [x] TASK-052: Integrar listagem por categoria com `GET /api/v1/produto/categoria/{categoriaId}`.\r\n 184: [x] TASK-053: Refletir pagina, tamanho e total de itens retornados pelo backend.\r\n 185: [x] TASK-054: Preservar filtros e busca na URL.\r\n 186: [x] TASK-055: Implementar estados de resultado vazio e erro recuperavel.\r\n 187: [x] TASK-056: Criar testes de integracao para busca e filtro por categoria.\r\n 188: \r\n 189: ### 8. Detalhe do produto\r\n 190: \r\n 191: [x] TASK-057: Implementar rota `/products/:id`.\r\n 192: [x] TASK-058: Integrar `GET /api/v1/produto/{id}`.\r\n 193: [x] TASK-059: Exibir imagem, titulo, descricao, modelo, categoria, preco e estoque.\r\n 194: [x] TASK-060: Exibir CTA de comprar agora e adicionar ao carrinho.\r\n 195: [ ] TASK-061: Tratar produto indisponivel ou sem estoque.\r\n 196: [ ] TASK-062: Redirecionar usuarios nao autenticados para login ao iniciar compra.\r\n 197: [ ] TASK-063: Criar testes de componente e fluxo para detalhe de produto.\r\n 198: \r\n 199: ### 9. Carrinho\r\n 200: \r\n 201: Observacao: a rota `/cart` ja existe como placeholder, sem store nem\r\n 202: integracao com a API.\r\n 203: \r\n 204: [ ] TASK-064: Criar store de dominio `Cart` com NgRx SignalStore.\r\n 205: [ ] TASK-065: Implementar criacao automatica de carrinho quando necessario.\r\n 206: [ ] TASK-066: Integrar `POST /api/v1/carrinho/criar`.\r\n 207: [ ] TASK-067: Integrar `GET /api/v1/carrinho/{carrinhoId}`.\r\n 208: [ ] TASK-068: Integrar `POST /api/v1/carrinho/items` sem enviar `carrinhoId`.\r\n 209: [ ] TASK-069: Integrar `PATCH /api/v1/carrinho/items/{itemId}` para quantidade.\r\n 210: [ ] TASK-070: Integrar `DELETE /api/v1/carrinho/items/{itemId}` para remocao.\r\n 211: [ ] TASK-071: Implementar rota `/cart`.\r\n 212: [ ] TASK-072: Implementar componentes `CartButton`, `CartItem`, `CartSummary` e `QuantitySelector`.\r\n 213: [ ] TASK-073: Manter resumo de valores consistente apos alteracoes.\r\n 214: [ ] TASK-074: Criar testes unitarios da store e testes de fluxo do carrinho.\r\n 215: \r\n 216: ### 10. Checkout\r\n 217: \r\n 218: [ ] TASK-075: Implementar rota protegida de checkout.\r\n 219: [ ] TASK-076: Reutilizar dados do carrinho ativo.\r\n 220: [ ] TASK-077: Carregar perfil do cliente para preencher endereco base.\r\n","exit_code":0,"status":"completed"}}
