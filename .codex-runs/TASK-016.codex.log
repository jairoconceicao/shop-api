DOM', () => {\r\n    render(<App />)\r\n\r\n    expect(\r\n      screen.getByRole('heading', { level: 1, name: 'shop-api' }),\r\n    ).toBeInTheDocument()\r\n  })\r\n})\r\n\r\n","exit_code":0,"status":"completed"}}
