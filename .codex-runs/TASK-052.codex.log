{"type":"item.completed","item":{"id":"item_14","type":"command_execution","command":"\"C:\\\\Program Files\\\\PowerShell\\\\7\\\\pwsh.exe\" -Command \"Get-Content frontend\\\\src\\\\app\\\\core\\\\category\\\\category.service.ts\"","aggregated_output":"import { inject, Injectable } from '@angular/core';\r\nimport { map, Observable } from 'rxjs';\r\n\r\nimport { ApiClientService, normalizeResponseData, type ApiResponse } from '@shared/api';\r\nimport type { Category } from '@shared/models';\r\n\r\n@Injectable({\r\n  providedIn: 'root',\r\n})\r\nexport class CategoryService {\r\n  private readonly apiClient = inject(ApiClientService);\r\n\r\n  listPublicCategories(): Observable<Category[]> {\r\n    return this.apiClient\r\n      .get<ApiResponse<Category[]>>('/api/v1/categoria')\r\n      .pipe(map((response: ApiResponse<Category[]>) => normalizeResponseData(response)));\r\n  }\r\n}\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"\"C:\\\\Program Files\\\\PowerShell\\\\7\\\\pwsh.exe\" -Command \"Get-Content frontend\\\\src\\\\app\\\\domains\\\\catalog\\\\products-page-filters.context.ts\"","aggregated_output":"import { inject, signal, type Signal } from '@angular/core';\r\n\r\nimport { CategoryService } from '@core/category/category.service';\r\nimport type { Category } from '@shared/models';\r\n\r\nimport { createRemoteSectionState } from '../home/home-page.context';\r\n\r\nexport interface ProductsPageFiltersState {\r\n  readonly categories: Signal<readonly Category[]>;\r\n  readonly isLoadingCategories: Signal<boolean>;\r\n  readonly categoriesError: Signal<string | null>;\r\n  readonly isCategoriesEmpty: Signal<boolean>;\r\n  readonly selectedCategoryId: Signal<number | null>;\r\n  reloadCategories(): void;\r\n  selectCategory(categoryId: number | null): void;\r\n}\r\n\r\nexport function createProductsPageFiltersState(): ProductsPageFiltersState {\r\n  const categoryService = inject(CategoryService);\r\n  const selectedCategoryId = signal<number | null>(null);\r\n\r\n  const categoriesState = createRemoteSectionState<Category>(\r\n    () => categoryService.listPublicCategories(),\r\n    'Nao foi possivel carregar as categorias. Tente novamente.',\r\n  );\r\n\r\n  return {\r\n    categories: categoriesState.items,\r\n    isLoadingCategories: categoriesState.isLoading,\r\n    categoriesError: categoriesState.error,\r\n    isCategoriesEmpty: categoriesState.isEmpty,\r\n    selectedCategoryId,\r\n    reloadCategories: categoriesState.reload,\r\n    selectCategory(categoryId: number | null): void {\r\n      selectedCategoryId.set(categoryId);\r\n    },\r\n  };\r\n}\r\n","exit_code":0,"status":"completed"}}
