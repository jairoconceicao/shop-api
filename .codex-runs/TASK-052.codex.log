:                <a href=\"produto.html\" class=\"btn-secondary !py-2 !px-2 text-xs\">Ver detalhe</a>\ndocs/ideacao/index.html-200-                <button class=\"btn-primary !py-2 !px-2 text-xs\" data-add-to-cart data-id=\"p7\" data-name=\"Cadeira Gamer\" data-price=\"1149\">Adicionar</button>\ndocs/ideacao/index.html-201-              </div>\ndocs/ideacao/index.html-202-            </div>\ndocs/ideacao/index.html-203-          </article>\ndocs/ideacao/index.html-204-\ndocs/ideacao/index.html-205-          <!-- Card 8 -->\ndocs/ideacao/index.html-206-          <article class=\"card card-hover group\">\ndocs/ideacao/index.html:207:            <a href=\"produto.html\" class=\"product-media\">\ndocs/ideacao/index.html-208-              <span class=\"text-zinc-700 text-3xl font-black\">img</span>\ndocs/ideacao/index.html-209-            </a>\ndocs/ideacao/index.html-210-            <div class=\"p-4\">\ndocs/ideacao/index.html-211-              <p class=\"eyebrow\">Headset</p>\ndocs/ideacao/index.html-212-              <h3 class=\"mt-1 font-semibold text-zinc-100 line-clamp-2\">Headset 7.1 Surround RGB USB</h3>\ndocs/ideacao/index.html-213-              <div class=\"mt-2 flex items-baseline gap-2\">\ndocs/ideacao/index.html-214-                <span class=\"price text-lg\">R$ 429</span>\ndocs/ideacao/index.html-215-              </div>\ndocs/ideacao/index.html-216-              <p class=\"mt-1.5 text-xs text-emerald-400\">● Em estoque</p>\ndocs/ideacao/index.html-217-              <div class=\"mt-4 grid grid-cols-2 gap-2\">\ndocs/ideacao/index.html:218:                <a href=\"produto.html\" class=\"btn-secondary !py-2 !px-2 text-xs\">Ver detalhe</a>\ndocs/ideacao/index.html-219-                <button class=\"btn-primary !py-2 !px-2 text-xs\" data-add-to-cart data-id=\"p8\" data-name=\"Headset 7.1\" data-price=\"429\">Adicionar</button>\ndocs/ideacao/index.html-220-              </div>\ndocs/ideacao/index.html-221-            </div>\ndocs/ideacao/index.html-222-          </article>\ndocs/ideacao/index.html-223-        </div>\ndocs/ideacao/index.html-224-      </section>\ndocs/ideacao/index.html-225-    </main>\ndocs/ideacao/index.html-226-\nimport type { LinkProps } from 'react-router-dom'\r\nimport { Link } from 'react-router-dom'\r\nimport {\r\n  getButtonClasses,\r\n  type ButtonSize,\r\n  type ButtonVariant,\r\n} from './buttonStyles'\r\n\r\nexport interface LinkButtonProps extends LinkProps {\r\n  variant?: ButtonVariant\r\n  size?: ButtonSize\r\n}\r\n\r\nexport function LinkButton({\r\n  variant = 'primary',\r\n  size = 'md',\r\n  className,\r\n  ...props\r\n}: LinkButtonProps) {\r\n  return (\r\n    <Link\r\n      className={getButtonClasses({ variant, size, className })}\r\n      {...props}\r\n    />\r\n  )\r\n}\r\n\r\nimport type { HTMLAttributes } from 'react'\r\nimport {\r\n  getSurfaceClasses,\r\n  type SurfaceVariant,\r\n} from './surfaceStyles'\r\n\r\nexport interface SurfaceProps extends HTMLAttributes<HTMLDivElement> {\r\n  variant?: SurfaceVariant\r\n}\r\n\r\nexport function Surface({\r\n  variant = 'base',\r\n  className,\r\n  ...props\r\n}: SurfaceProps) {\r\n  return (\r\n    <div className={getSurfaceClasses(variant, className)} {...props} />\r\n  )\r\n}\r\n\r\nimport { LinkButton } from '../../shared/ui/buttons/LinkButton'\r\n\r\nexport function NotFoundPage() {\r\n  return (\r\n    <section className=\"container-page flex min-h-dvh items-center justify-center py-12 text-center\">\r\n      <div className=\"flex max-w-xl flex-col items-center\">\r\n        <p className=\"text-sm font-semibold uppercase tracking-[0.3em] text-brand-400\">\r\n          Erro 404\r\n        </p>\r\n        <h1 className=\"mt-4 text-4xl font-bold tracking-tight text-zinc-50 sm:text-5xl\">\r\n          Página não encontrada\r\n        </h1>\r\n        <p className=\"mt-4 text-base leading-7 text-zinc-400\">\r\n          O endereço informado não existe ou não está mais disponível.\r\n        </p>\r\n        <LinkButton to=\"/\" size=\"lg\" className=\"mt-8\">\r\n          Voltar ao catálogo\r\n        </LinkButton>\r\n      </div>\r\n    </section>\r\n  )\r\n}\r\n\r\nimport type { FormEvent } from 'react'\r\nimport { Link, useNavigate } from 'react-router-dom'\r\n\r\nimport { DropdownMenu } from '../../shared/ui/overlays/DropdownMenu'\r\n\r\nexport interface HeaderCustomer {\r\n  name: string\r\n  email: string\r\n}\r\n\r\nexport interface HeaderCategory {\r\n  id: number\r\n  title: string\r\n}\r\n\r\nexport interface HeaderProps {\r\n  categories?: readonly HeaderCategory[]\r\n  customer?: HeaderCustomer | null\r\n  onSignOut?: () => void\r\n}\r\n\r\nfunction Icon({ children }: { children: React.ReactNode }) {\r\n  return (\r\n    <svg\r\n      aria-hidden=\"true\"\r\n      className=\"size-5 shrink-0\"\r\n      viewBox=\"0 0 24 24\"\r\n      fill=\"none\"\r\n      stroke=\"currentColor\"\r\n      strokeWidth=\"2\"\r\n      strokeLinecap=\"round\"\r\n      strokeLinejoin=\"round\"\r\n    >\r\n      {children}\r\n    </svg>\r\n  )\r\n}\r\n\r\nconst menuItemClasses =\r\n  'flex min-h-10 w-full items-center gap-3 rounded-xl px-3 text-left text-sm text-zinc-200 hover:bg-ink-700 hover:text-zinc-50'\r\n\r\nfunction SearchForm() {\r\n  const navigate = useNavigate()\r\n\r\n  function handleSubmit(event: FormEvent<HTMLFormElement>) {\r\n    event.preventDefault()\r\n    const query = new FormData(event.currentTarget).get('busca')?.toString().trim()\r\n    navigate(query ? `/?busca=${encodeURIComponent(query)}` : '/')\r\n  }\r\n\r\n  return (\r\n    <form className=\"w-full md:max-w-2xl md:flex-1\" role=\"search\" onSubmit={handleSubmit}>\r\n      <label className=\"relative block\">\r\n        <span className=\"sr-only\">Buscar produtos</span>\r\n        <span className=\"pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-zinc-500\">\r\n          <Icon>\r\n            <circle cx=\"11\" cy=\"11\" r=\"7\" />\r\n            <path d=\"m21 21-4.3-4.3\" />\r\n          </Icon>\r\n        </span>\r\n        <input\r\n          name=\"busca\"\r\n          type=\"search\"\r\n          placeholder=\"Buscar produtos, marcas e mais...\"\r\n          className=\"min-h-11 w-full rounded-xl border border-ink-700 bg-ink-800 py-2.5 pl-11 pr-4 text-sm text-zinc-100 placeholder:text-zinc-500 hover:border-ink-600 focus:border-brand-500 focus:outline-none\"\r\n        />\r\n      </label>\r\n    </form>\r\n  )\r\n}\r\n\r\nfunction CustomerMenu({ customer, onSignOut }: HeaderProps) {\r\n  return (\r\n    <DropdownMenu\r\n      label=\"Área do cliente\"\r\n      trigger={\r\n        <>\r\n          <Icon>\r\n            <circle cx=\"12\" cy=\"8\" r=\"4\" />\r\n            <path d=\"M4 21a8 8 0 0 1 16 0\" />\r\n          </Icon>\r\n          <span className=\"hidden text-sm sm:inline\">{customer ? 'Minha conta' : 'Entrar'}</span>\r\n        </>\r\n      }\r\n    >\r\n      {customer ? (\r\n        <>\r\n          <div className=\"border-b border-ink-700 px-3 pb-3 pt-1\">\r\n            <p className=\"truncate text-sm font-semibold text-zinc-100\">{customer.name}</p>\r\n            <p className=\"truncate text-xs text-zinc-500\">{customer.email}</p>\r\n          </div>\r\n          <Link className={`${menuItemClasses} mt-1`} to=\"/pedidos\" role=\"menuitem\">\r\n            Meus pedidos\r\n          </Link>\r\n          <Link className={menuItemClasses} to=\"/minha-conta/dados\" role=\"menuitem\">\r\n            Meus dados\r\n          </Link>\r\n          <Link className={menuItemClasses} to=\"/minha-conta/senha\" role=\"menuitem\">\r\n            Trocar senha\r\n          </Link>\r\n          <button\r\n            className={`${menuItemClasses} border-t border-ink-700 text-rose-300 hover:bg-rose-500/10 hover:text-rose-200`}\r\n            type=\"button\"\r\n            role=\"menuitem\"\r\n            onClick={onSignOut}\r\n          >\r\n            Sair\r\n          </button>\r\n        </>\r\n      ) : (\r\n        <Link className={menuItemClasses} to=\"/entrar\" role=\"menuitem\">\r\n          Entrar\r\n        </Link>\r\n      )}\r\n    </DropdownMenu>\r\n  )\r\n}\r\n\r\nfunction CategoryNavigation({ categories }: Pick<HeaderProps, 'categories'>) {\r\n  return (\r\n    <nav aria-label=\"Categorias de produtos\" className=\"border-t border-ink-800\">\r\n      <div className=\"container-page overflow-x-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden\">\r\n        <ul className=\"flex min-w-max items-center gap-1 py-2\">\r\n          <li>\r\n            <Link\r\n              className=\"flex min-h-10 items-center whitespace-nowrap rounded-xl px-3 text-sm font-medium text-brand-400 hover:bg-ink-800 hover:text-brand-300\"\r\n              to=\"/\"\r\n            >\r\n              Todas as categorias\r\n            </Link>\r\n          </li>\r\n          {categories?.map((category) => (\r\n            <li key={category.id}>\r\n              <Link\r\n                className=\"flex min-h-10 items-center whitespace-nowrap rounded-xl px-3 text-sm text-zinc-300 hover:bg-ink-800 hover:text-zinc-50\"\r\n                to={`/?categoria=${encodeURIComponent(category.id)}`}\r\n              >\r\n                {category.title}\r\n              </Link>\r\n            </li>\r\n          ))}\r\n        </ul>\r\n      </div>\r\n    </nav>\r\n  )\r\n}\r\n\r\nexport function Header({ categories = [], customer = null, onSignOut }: HeaderProps) {\r\n  return (\r\n    <header className=\"sticky top-0 z-30 border-b border-ink-800 bg-ink-950/90 backdrop-blur-xl\">\r\n      <div className=\"container-page py-2.5\">\r\n        <div className=\"flex items-center gap-2 sm:gap-3\">\r\n          <Link className=\"flex min-h-11 shrink-0 items-center gap-2 rounded-xl\" to=\"/\" aria-label=\"Shop — ir ao catálogo\">\r\n            <span className=\"grid size-9 place-items-center rounded-xl bg-brand-500 font-black text-ink-950\">\r\n              S\r\n            </span>\r\n            <span className=\"hidden text-lg font-bold tracking-tight text-zinc-50 sm:inline\">\r\n              shop<span className=\"text-brand-400\">.</span>\r\n            </span>\r\n          </Link>\r\n\r\n          <div className=\"hidden min-w-0 flex-1 md:flex\">\r\n            <SearchForm />\r\n          </div>\r\n\r\n          <nav className=\"ml-auto flex items-center gap-1\" aria-label=\"Ações da loja\">\r\n            <Link\r\n              className=\"flex min-h-10 items-center gap-2 rounded-xl px-3 text-zinc-200 hover:bg-ink-750\"\r\n              to=\"/carrinho\"\r\n              aria-label=\"Carrinho\"\r\n            >\r\n              <Icon>\r\n                <circle cx=\"9\" cy=\"20\" r=\"1\" />\r\n                <circle cx=\"19\" cy=\"20\" r=\"1\" />\r\n                <path d=\"M3 3h2l2.4 12.4A2 2 0 0 0 9.4 17h8.2a2 2 0 0 0 2-1.6L22 7H6\" />\r\n              </Icon>\r\n              <span className=\"hidden text-sm lg:inline\">Carrinho</span>\r\n            </Link>\r\n            <CustomerMenu customer={customer} onSignOut={onSignOut} />\r\n          </nav>\r\n        </div>\r\n\r\n        <div className=\"pt-2 md:hidden\">\r\n          <SearchForm />\r\n        </div>\r\n      </div>\r\n      <CategoryNavigation categories={categories} />\r\n    </header>\r\n  )\r\n}\r\n\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_9","type":"agent_message","text":"Proposta de design para a TASK-052:\n\n- Criar `HomePage` em `features/catalog/pages/`.\n- Substituir somente o placeholder da rota `/`.\n- Hero responsivo inspirado no protótipo, com linguagem neutra sobre catálogo de tecnologia, sem promoções, descontos, frete ou entrega.\n- CTA “Ver produtos” apontando para a região `#catalogo`.\n- Criar a região semântica do catálogo com título e espaço para a integração futura, sem grid, queries, filtros, categorias ou paginação — todos pertencem às próximas tarefas.\n- Testar conteúdo, semântica, CTA e ausência das alegações proibidas.\n- Atualizar apenas a TASK-052 no backlog.\n\nAlternativas consideradas:\n\n1. Página única e coesa em `HomePage` — recomendada, por ser pequena e compatível com o escopo.\n2. Separar `Hero` e `CatalogSection` em componentes — adicionaria abstração prematura.\n3. Integrar componentes/queries de catálogo — invadiria a TASK-053.\n\nPosso seguir com a opção 1?"}}
