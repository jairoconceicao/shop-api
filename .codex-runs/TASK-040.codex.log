sition hover:border-white hover:bg-white/10\"\r\n            >\r\n              Explorar catalogo\r\n            </a>\r\n          </div>\r\n        </article>\r\n        <app-register-form />\r\n      </section>\r\n    </app-page-container>\r\n  `,\r\n  changeDetection: ChangeDetectionStrategy.OnPush,\r\n})\r\nexport class RegisterPageComponent {}\r\n","exit_code":0,"status":"completed"}}
