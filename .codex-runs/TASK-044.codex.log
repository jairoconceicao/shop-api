eSchema = z.object({\r\n  error: z\r\n    .object({\r\n      code: z.string().optional(),\r\n      message: z.string().optional(),\r\n      details: z.unknown().optional(),\r\n    })\r\n    .optional(),\r\n})\r\n\r\nexport type ApiErrorResponse = z.infer<typeof apiErrorResponseSchema>\r\n\r\nopenapi.yaml-62-        '422':\r\nopenapi.yaml-63-          description: Unprocessable Entity\r\nopenapi.yaml-64-          content:\r\nopenapi.yaml-65-            application/json:\r\nopenapi.yaml-66-              schema:\r\nopenapi.yaml-67-                \"$ref\": \"#/components/schemas/ApiErrorResponse\"\r\nopenapi.yaml-68-      security:\r\nopenapi.yaml-69-      - Bearer: []\r\nopenapi.yaml:70:  \"/api/v1/cliente/{clienteId}\":\r\nopenapi.yaml-71-    get:\r\nopenapi.yaml-72-      tags:\r\nopenapi.yaml-73-      - Clientes\r\nopenapi.yaml-74-      parameters:\r\nopenapi.yaml-75-      - name: clienteId\r\nopenapi.yaml-76-        in: path\r\nopenapi.yaml-77-        required: true\r\nopenapi.yaml-78-        schema:\r\n--\nopenapi.yaml-189-        '422':\r\nopenapi.yaml-190-          description: Unprocessable Entity\r\nopenapi.yaml-191-          content:\r\nopenapi.yaml-192-            application/json:\r\nopenapi.yaml-193-              schema:\r\nopenapi.yaml-194-                \"$ref\": \"#/components/schemas/ApiErrorResponse\"\r\nopenapi.yaml-195-      security:\r\nopenapi.yaml-196-      - Bearer: []\r\nopenapi.yaml:197:  \"/api/v1/cliente/{clienteId}/senha\":\r\nopenapi.yaml-198-    put:\r\nopenapi.yaml-199-      tags:\r\nopenapi.yaml-200-      - Clientes\r\nopenapi.yaml-201-      parameters:\r\nopenapi.yaml-202-      - name: clienteId\r\nopenapi.yaml-203-        in: path\r\nopenapi.yaml-204-        required: true\r\nopenapi.yaml-205-        schema:\r\n--\nopenapi.yaml-234-        '422':\r\nopenapi.yaml-235-          description: Unprocessable Entity\r\nopenapi.yaml-236-          content:\r\nopenapi.yaml-237-            application/json:\r\nopenapi.yaml-238-              sch