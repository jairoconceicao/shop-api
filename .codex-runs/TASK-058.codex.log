{"type":"item.completed","item":{"id":"item_14","type":"command_execution","command":"\"C:\\\\Program Files\\\\PowerShell\\\\7\\\\pwsh.exe\" -Command 'Get-Content -Path frontend/src/app/domains/home/home-page.context.ts'","aggregated_output":"import { DestroyRef, computed, inject, signal, type Signal } from '@angular/core';\r\nimport type { Observable, Subscription } from 'rxjs';\r\n\r\nexport interface RemoteSectionState<T> {\r\n  readonly items: Signal<readonly T[]>;\r\n  readonly isLoading: Signal<boolean>;\r\n  readonly error: Signal<string | null>;\r\n  readonly isEmpty: Signal<boolean>;\r\n  reload(): void;\r\n}\r\n\r\nexport function createRemoteSectionState<T>(\r\n  loader: () => Observable<readonly T[]>,\r\n  errorMessage: string,\r\n): RemoteSectionState<T> {\r\n  const destroyRef = inject(DestroyRef);\r\n  const items = signal<readonly T[]>([]);\r\n  const isLoading = signal(true);\r\n  const error = signal<string | null>(null);\r\n\r\n  let subscription: Subscription | null = null;\r\n\r\n  const reload = (): void => {\r\n    subscription?.unsubscribe();\r\n    isLoading.set(true);\r\n    error.set(null);\r\n\r\n    subscription = loader().subscribe({\r\n      next: (value) => {\r\n        items.set(value);\r\n        isLoading.set(false);\r\n      },\r\n      error: () => {\r\n        items.set([]);\r\n        error.set(errorMessage);\r\n        isLoading.set(false);\r\n      },\r\n    });\r\n  };\r\n\r\n  destroyRef.onDestroy(() => subscription?.unsubscribe());\r\n  reload();\r\n\r\n  return {\r\n    items,\r\n    isLoading,\r\n    error,\r\n    isEmpty: computed(() => !isLoading() && !error() && items().length === 0),\r\n    reload,\r\n  };\r\n}\r\n","exit_code":0,"status":"completed"}}
