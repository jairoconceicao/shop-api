Input, { target: { value: 'notebook gamer' } });\n    fireEvent.submit(searchInput.closest('form') as HTMLFormElement);\n\n    expect(catalogServiceMock.listPublicProducts).toHaveBeenNthCalledWith(2, {\n      page: 1,\n      size: 8,\n      searchword: 'notebook gamer',\n    });\n    expect(await screen.findByRole('heading', { name: 'Notebook Gamer Pro' })).toBeVisible();\n  });\n\n  it('keeps the search term when the user searches and then applies a category filter', async () => {\n    const categories = [\n      {\n        categoriaId: 1,\n        titulo: 'Informática',\n        descricao: 'Produtos de tecnologia',\n      },\n      {\n        categoriaId: 2,\n        titulo: 'Celulares',\n        descricao: 'Smartphones e acessórios',\n      },\n    ] satisfies Category[];\n\n    const initialPage = {\n      status: true,\n      message: 'Catalogo de produtos carregado com sucesso.',\n      pagination: {\n        pages: 1,\n        size: 8,\n        totalItems: 1,\n        data: [\n          {\n            produtoId: 101,\n            titulo: 'Notebook Gamer',\n            thumb: null,\n            preco: 5999.9,\n            estoque: 12,\n            categoria: {\n              categoriaId: 1,\n              titulo: 'Informática',\n            },\n          },\n        ],\n      },\n    } satisfies PagedResponse<ProductCatalogItem>;\n\n    const searchedPage = {\n      status: true,\n      message: 'Catalogo de produtos carregado com sucesso.',\n      pagination: {\n        pages: 1,\n        size: 8,\n        totalItems: 1,\n        data: [\n          {\n            produtoId: 202,\n            titulo: 'Notebook Gamer Pro',\n            thumb: null,\n            preco: 7999.9,\n            estoque: 4,\n            categoria: {\n              categoriaId: 1,\n              titulo: 'Informática',\n            },\n          },\n        ],\n      },\n    } satisfies PagedResponse<ProductCatalogItem>;\n\n    const categoryPage = {\n      status: true,\n      message: