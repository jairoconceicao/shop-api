pping>R$ 0,00</dd>\ndocs/ideacao\\carrinho.html-51-            </div>\ndocs/ideacao\\carrinho.html-52-            <div class=\"flex items-center justify-between text-emerald-300\">\ndocs/ideacao\\carrinho.html-53-              <dt>Pix (5%)</dt>\ndocs/ideacao\\carrinho.html:54:              <dd class=\"font-medium\">Aplicado no checkout</dd>\ndocs/ideacao\\carrinho.html-55-            </div>\ndocs/ideacao\\carrinho.html-56-          </dl>\ndocs/ideacao\\carrinho.html-57-          <div class=\"hairline my-4\"></div>\ndocs/ideacao\\carrinho.html-58-          <div class=\"flex items-baseline justify-between\">\n--\ndocs/ideacao\\login.html-3-  <head>\ndocs/ideacao\\login.html-4-    <meta charset=\"utf-8\" />\ndocs/ideacao\\login.html-5-    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\ndocs/ideacao\\login.html-6-    <title>shop. — Entrar</title>\ndocs/ideacao\\login.html:7:    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" />\ndocs/ideacao\\login.html:8:    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin />\ndocs/ideacao\\login.html:9:    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap\" rel=\"stylesheet\" />\ndocs/ideacao\\login.html-10-    <script src=\"js/theme.js\"></script>\ndocs/ideacao\\login.html-11-    <script src=\"https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4\"></script>\ndocs/ideacao\\login.html-12-  </head>\ndocs/ideacao\\login.html-13-  <body class=\"min-h-dvh\">\n--\ndocs/ideacao\\login.html-17-    <main class=\"container-page py-16\">\ndocs/ideacao\\login.html-18-      <div class=\"mx-auto max-w-md\">\ndocs/ideacao\\login.html-19-        <div class=\"surface-raised p-8\">\ndocs/ideacao\\login.html-20-          <div class=\"text-center\">\ndocs/ideacao\\login.html:21:            <span class=\"inline-grid place-items-center h-12 w-12 rounded-2xl bg-brand-500 text-ink-950 font-black text-xl\">S</span>\ndocs/ideacao\\login.html:22:    